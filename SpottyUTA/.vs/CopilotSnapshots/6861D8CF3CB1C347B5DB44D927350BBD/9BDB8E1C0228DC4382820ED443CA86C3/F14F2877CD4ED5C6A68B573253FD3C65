using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;
using SpottyUTA.Data;
using System.Diagnostics;

namespace SpottyUTA.Controllers
{
    public class HomeController : Controller
    {
        private readonly SpottyUtaContext _context;

        // Inyectamos el contexto de la base de datos en el constructor
        public HomeController(SpottyUtaContext context)
        {
            _context = context;
        }

        public async Task<IActionResult> Index()
        {
            DateTime ahoraDateTime = DateTime.Now;
            DateOnly fechaActual = DateOnly.FromDateTime(ahoraDateTime);
            TimeOnly horaActualTime = TimeOnly.FromDateTime(ahoraDateTime);

            ViewBag.DiaSemana = ahoraDateTime.DayOfWeek;

            // 1. Traer todas las reservas activas de hoy para cruzarlas con las salas
            var reservasHoy = await _context.Reservas
                .Where(r => r.Fecha == fechaActual && r.EstadoReserva == "Activa")
                .OrderBy(r => r.HoraInicio)
                .ToListAsync();

            // Pasamos las reservas por ViewBag para armar las agendas dentro de los modales
            ViewBag.ReservasHoy = reservasHoy;

            // 2. Traer las salas base de la base de datos
            var querySalas = _context.Salas.AsQueryable();
            if (ahoraDateTime.DayOfWeek == DayOfWeek.Sunday) return View(new List<Models.Sala>());
            if (ahoraDateTime.DayOfWeek == DayOfWeek.Saturday) querySalas = querySalas.Where(s => s.Piso == 1);

            var salas = await querySalas.OrderBy(s => s.Piso).ThenBy(s => s.Nombre).ToListAsync();

            // 3. DINÁMICA DE ESTADOS: Calcular en tiempo real si corresponde cambiar a "O" u "R"
            foreach (var sala in salas)
            {
                var reservasDeEstaSala = reservasHoy.Where(r => r.SalaId == sala.Id).ToList();

                // ¿Hay alguien adentro usando la sala justo ahora? -> Estado "O"
                bool estaOcupadaAhora = reservasDeEstaSala.Any(r => horaActualTime >= r.HoraInicio && horaActualTime < r.HoraFin);

                if (estaOcupadaAhora)
                {
                    sala.EstadoActual = "O";
                }
                else
                {
                    // ¿Hay una reserva futura que empiece en menos de 20 minutos? -> Estado "R"
                    // Usamos tu regla: si (HoraInicioReserva - HoraActual) <= 20 minutos
                    bool proximaReservaCercana = reservasDeEstaSala.Any(r =>
                        r.HoraInicio > horaActualTime &&
                        (r.HoraInicio.ToTimeSpan() - horaActualTime.ToTimeSpan()).TotalMinutes <= 20);

                    if (proximaReservaCercana)
                    {
                        sala.EstadoActual = "R";
                    }
                    else
                    {
                        sala.EstadoActual = "D"; // Totalmente libre para un "estudio corto"
                    }
                }
            }

            return View(salas);
        }

        public IActionResult Privacy()
        {
            return View();
        }
        public IActionResult Reglamento()
        {
            return View();
        }
    }
}