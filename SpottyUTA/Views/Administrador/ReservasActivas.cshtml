@{
    Layout = null;
    var nombreAdmin = ViewBag.NombreAdministrador as string ?? "Administrador";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reservas Activas - Spotty UTA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
</head>
<body class="admin-body">

    <div class="admin-layout">

        <!-- Sidebar Izquierda -->
        <aside class="admin-sidebar">
            <div class="sidebar-brand">
                <img src="/logo-uta.png" alt="Escudo UTA" class="brand-logo-img" />
                <h1 class="brand-text">SPOTTY <span>UTA</span></h1>
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a href="@Url.Action("Dashboard", "Administrador")" class="menu-item-link">
                        <i class="fa-solid fa-border-all"></i>
                        <span class="menu-item-text">Dashboard</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ReservasActivas", "Administrador")" class="menu-item-link active">
                        <i class="fa-regular fa-calendar-check"></i>
                        <span class="menu-item-text">Reservas Activas</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GestionSalas", "Administrador")" class="menu-item-link">
                        <i class="fa-solid fa-door-open"></i>
                        <span class="menu-item-text">Gestión de Salas</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Usuarios", "Administrador")" class="menu-item-link">
                        <i class="fa-regular fa-user"></i>
                        <span class="menu-item-text">Usuarios</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                <a href="@Url.Action("CerrarSesion", "Auth")" class="sidebar-collapse-btn">
                    <i class="fa-solid fa-arrow-right-from-bracket text-danger"></i>
                    <span class="menu-item-text">Cerrar Sesión</span>
                </a>
            </div>
        </aside>

        <!-- Contenedor Principal -->
        <div class="admin-main-container">

            <!-- Top Header -->
            <header class="admin-top-header">
                <div class="d-flex align-items-center gap-3">
                    <span class="header-role-label">Administrador</span>
                </div>

                <div class="header-right-actions">
                    <!-- Campana Notificaciones con Dropdown Interactivo -->
                    <div class="dropdown">
                        <button type="button" class="btn notification-bell-container p-0 border-0" id="notifDropdownTriggerReservas" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fa-regular fa-bell bell-icon"></i>
                            <span class="notification-badge" id="notifBadgeCountReservas">3</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end notification-dropdown-menu mt-2">
                            <div class="p-3 text-white d-flex align-items-center justify-content-between" style="background-color: #0F172A;">
                                <h6 class="fw-bold mb-0 text-white" style="font-size: 0.88rem;">
                                    <i class="fa-solid fa-bell text-warning me-2"></i>Notificaciones
                                </h6>
                                <span class="badge bg-warning text-dark fw-bold" style="font-size: 0.7rem;">3 Nuevas</span>
                            </div>
                            <div style="max-height: 280px; overflow-y: auto;">
                                <div class="p-3 border-bottom text-start bg-white" style="transition: background-color 0.15s ease;">
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <span class="fw-bold" style="color: #0F172A; font-size: 0.84rem;"><i class="fa-solid fa-circle-exclamation text-warning me-2"></i>Box 3 próximo a vencer</span>
                                        <span style="color: #64748B; font-size: 0.7rem; font-weight: 600;">Hace 5m</span>
                                    </div>
                                    <p class="mb-0" style="color: #334155; font-size: 0.78rem; font-weight: 500; line-height: 1.35;">Quedan menos de 15 minutos para la reserva activa en Box 3.</p>
                                </div>
                                <div class="p-3 border-bottom text-start bg-white" style="transition: background-color 0.15s ease;">
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <span class="fw-bold" style="color: #0F172A; font-size: 0.84rem;"><i class="fa-solid fa-user-xmark text-danger me-2"></i>Usuario sancionado</span>
                                        <span style="color: #64748B; font-size: 0.7rem; font-weight: 600;">Hace 20m</span>
                                    </div>
                                    <p class="mb-0" style="color: #334155; font-size: 0.78rem; font-weight: 500; line-height: 1.35;">El estudiante acumuló 3 faltas y fue bloqueado automáticamente.</p>
                                </div>
                                <div class="p-3 text-start bg-white" style="transition: background-color 0.15s ease;">
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <span class="fw-bold" style="color: #0F172A; font-size: 0.84rem;"><i class="fa-solid fa-circle-check text-success me-2"></i>Sistema Operativo</span>
                                        <span style="color: #64748B; font-size: 0.7rem; font-weight: 600;">Hoy 08:00</span>
                                    </div>
                                    <p class="mb-0" style="color: #334155; font-size: 0.78rem; font-weight: 500; line-height: 1.35;">12 boxes de estudio disponibles para reserva hoy.</p>
                                </div>
                            </div>
                            <div class="p-2.5 text-center border-top" style="background-color: #F8FAFC;">
                                <button type="button" class="btn btn-link text-decoration-none fw-bold p-0" style="color: #2563EB; font-size: 0.78rem;" onclick="document.querySelectorAll('.notification-badge').forEach(b => b.style.display='none');">
                                    <i class="fa-solid fa-check-double me-1"></i>Marcar todas como leídas
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Perfil Dropdown -->
                    <div class="admin-profile-dropdown">
                        <div class="profile-avatar-circle">
                            @{
                                var initials = "";
                                if (nombreAdmin.Contains(" "))
                                {
                                    var parts = nombreAdmin.Split(' ');
                                    if (parts.Length >= 2) initials = (parts[0][0].ToString() + parts[1][0].ToString()).ToUpper();
                                    else initials = parts[0][0].ToString().ToUpper();
                                }
                                else if (nombreAdmin.Length > 0)
                                {
                                    initials = nombreAdmin.Substring(0, Math.Min(2, nombreAdmin.Length)).ToUpper();
                                }
                                @initials
                            }
                        </div>
                        <span class="profile-name-text">@nombreAdmin</span>
                        <i class="fa-solid fa-chevron-down profile-chevron"></i>
                    </div>
                </div>
            </header>

            <!-- Content Area (Updated via SignalR) -->
            <div id="reservas-activas-content-area">
                @await Html.PartialAsync("_ReservasActivasContent")
            </div>

        </div>

    </div>

    <!-- Modal Bootstrap: Liberar Box Sin Penalización -->
    <div class="modal fade" id="modalLiberarSinPenalizacion" tabindex="-1" aria-labelledby="modalLiberarLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <form asp-controller="Reservas" asp-action="GestionarAccionDashboard" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="reservaId" id="modalLiberarReservaId" />
                    <input type="hidden" name="accion" value="liberar" />
                    
                    <div class="modal-header border-bottom px-4 pt-4 pb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background-color: #FEF3C7; color: #D97706;">
                                <i class="fa-solid fa-door-open fs-5"></i>
                            </div>
                            <div>
                                <h5 class="modal-title fw-bold text-dark mb-0" id="modalLiberarLabel">Liberar Box sin Penalización</h5>
                                <span class="text-muted small">Confirmación de liberación anticipada</span>
                            </div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body px-4 py-4 text-secondary" style="font-size: 0.92rem;">
                        <p class="mb-3">¿Estás seguro de que deseas liberar la reserva de <strong id="modalLiberarAlumno" class="text-dark"></strong> en la <strong id="modalLiberarSala" class="text-dark"></strong>?</p>
                        <div class="p-3 rounded-3 bg-light border text-muted d-flex align-items-start gap-3" style="font-size: 0.85rem;">
                            <i class="fa-solid fa-circle-info text-primary fs-5 flex-shrink-0 mt-0.5"></i>
                            <span>Esta acción dejará el box disponible de inmediato para otros estudiantes sin registrar inasistencias ni penalizar la cuenta del alumno.</span>
                        </div>
                    </div>

                    <div class="modal-footer border-top px-4 py-3 bg-light rounded-bottom-4">
                        <button type="button" class="btn btn-outline-secondary px-4 fw-semibold rounded-3" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn text-white px-4 fw-bold rounded-3 shadow-sm d-inline-flex align-items-center justify-content-center gap-2" style="background-color: #F59E0B; border: none;">
                            <i class="fa-solid fa-check"></i>
                            <span>Sí, Liberar Box</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Bootstrap: Marcar Inasistencia / Sancionar -->
    <div class="modal fade" id="modalMarcarFalta" tabindex="-1" aria-labelledby="modalFaltaLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <form asp-controller="Reservas" asp-action="GestionarAccionDashboard" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="reservaId" id="modalFaltaReservaId" />
                    <input type="hidden" name="accion" value="falta" />
                    
                    <div class="modal-header border-bottom px-4 pt-4 pb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background-color: #FEE2E2; color: #DC2626;">
                                <i class="fa-solid fa-user-xmark fs-5"></i>
                            </div>
                            <div>
                                <h5 class="modal-title fw-bold text-dark mb-0" id="modalFaltaLabel">Registrar Inasistencia</h5>
                                <span class="text-muted small">Sanción por no presentación</span>
                            </div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body px-4 py-4 text-secondary" style="font-size: 0.92rem;">
                        <p class="mb-3">¿Confirmas que el alumno <strong id="modalFaltaAlumno" class="text-dark"></strong> no asistió a su reserva en la <strong id="modalFaltaSala" class="text-dark"></strong>?</p>
                        <div class="p-3 rounded-3 bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger d-flex align-items-start gap-3" style="font-size: 0.85rem;">
                            <i class="fa-solid fa-triangle-exclamation fs-5 flex-shrink-0 mt-0.5"></i>
                            <span>Esta acción liberará la sala y sumará <strong>1 falta acumulada</strong> al alumno. Si alcanza 3 faltas será bloqueado.</span>
                        </div>
                    </div>

                    <div class="modal-footer border-top px-4 py-3 bg-light rounded-bottom-4">
                        <button type="button" class="btn btn-outline-secondary px-4 fw-semibold rounded-3" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-danger px-4 fw-bold rounded-3 shadow-sm d-inline-flex align-items-center justify-content-center gap-2">
                            <i class="fa-solid fa-gavel"></i>
                            <span>Registrar Inasistencia</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Bootstrap: Guía de Acciones y Leyenda de Reservas -->
    <div class="modal fade" id="modalGuiaReservasActivas" tabindex="-1" aria-labelledby="modalGuiaReservasActivasLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <div class="modal-header border-bottom px-4 py-3.5">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-bg-blue rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="fa-solid fa-circle-info text-primary fs-5"></i>
                        </div>
                        <div>
                            <h5 class="modal-title fw-bold text-dark mb-0" id="modalGuiaReservasActivasLabel">
                                Guía de Acciones Rápidas y Leyenda de Estados
                            </h5>
                            <span class="text-muted small">Instrucciones de gestión presencial para recepción en biblioteca</span>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">

                    <!-- Sección 1: Acciones Rápidas -->
                    <div class="mb-4">
                        <h6 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2" style="font-size: 0.95rem;">
                            <i class="fa-solid fa-bolt text-primary"></i>
                            <span>Acciones de Gestión de Reservas</span>
                        </h6>

                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center gap-3 rounded-3" style="padding: 16px 20px; background-color: #ECFDF5; border-left: 5px solid #10B981;">
                                <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; font-size: 0.9rem;">
                                    <i class="fa-solid fa-circle-check"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-success mb-1" style="font-size: 0.92rem;">Marcar Ocupado</div>
                                    <div class="text-secondary small">El estudiante acude presencialmente al mesón. Confirma el uso activo del box de estudio.</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-3 rounded-3" style="padding: 16px 20px; background-color: #FFFBEB; border-left: 5px solid #F59E0B;">
                                <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; font-size: 0.9rem;">
                                    <i class="fa-solid fa-ban"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-warning-emphasis mb-1" style="font-size: 0.92rem; color: #92400E !important;">Cancelar sin Sanción</div>
                                    <div class="text-secondary small">Anula la reserva por imprevisto institucional o suspensión de clases sin penalizar al alumno.</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-3 rounded-3" style="padding: 16px 20px; background-color: #FEF2F2; border-left: 5px solid #EF4444;">
                                <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; font-size: 0.9rem;">
                                    <i class="fa-solid fa-user-xmark"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-danger mb-1" style="font-size: 0.92rem;">Marcar Falta</div>
                                    <div class="text-secondary small">Tras los 20 minutos de tolerancia sin presencia, libera la sala e incrementa el contador de inasistencias del usuario.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer border-top px-4 py-3 bg-light d-flex justify-content-end">
                    <button type="button" class="btn btn-primary px-4 py-2 fw-bold" style="border-radius: 10px; font-size: 0.85rem;" data-bs-dismiss="modal">
                        Entendido
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        // Configuración de SignalR para refresco en tiempo real
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/salasHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ActualizarMatrizSalas", function () {
            refrescarContenidoReservas();
        });

        connection.start().then(function () {
            console.log("SignalR conectado en Reservas Activas.");
        }).catch(function (err) {
            console.error("Error al conectar SignalR en Reservas Activas: ", err.toString());
        });

        function refrescarContenidoReservas() {
            fetch('/Administrador/ReservasActivas?partial=true')
                .then(response => response.text())
                .then(html => {
                    const area = document.getElementById('reservas-activas-content-area');
                    if (area) {
                        area.innerHTML = html;
                        syncCheckboxesFromState();
                        updateTableDisplay();
                        switchReservasTab(activeTab);
                    }
                })
                .catch(err => console.error("Error al refrescar reservas activas: ", err));
        }

        // Paginación y Filtros Locales
        let currentPage = 1;
        const pageSize = 5;
        let selectedFloors = [1, 2, 3];
        let selectedStates = ['reservado', 'ocupado'];
        let currentSearch = '';

        function syncCheckboxesFromState() {
            const allFloorsChecked = selectedFloors.length === 3;
            const chkAll = document.getElementById('chkPisoAll');
            if (chkAll) chkAll.checked = allFloorsChecked;

            [1, 2, 3].forEach(floor => {
                const chk = document.getElementById(`chkPiso${floor}`);
                if (chk) chk.checked = selectedFloors.includes(floor);
            });

            const chkRes = document.getElementById('chkEstReservado');
            if (chkRes) chkRes.checked = selectedStates.includes('reservado');

            const chkOcu = document.getElementById('chkEstOcupado');
            if (chkOcu) chkOcu.checked = selectedStates.includes('ocupado');

            const searchInput = document.querySelector('.panel-search-input');
            if (searchInput) searchInput.value = currentSearch;
        }

        function updateTableDisplay() {
            const rows = Array.from(document.querySelectorAll('.reserva-row'));
            const searchLower = currentSearch.toLowerCase().trim();

            const filteredRows = rows.filter(row => {
                const textContent = row.textContent.toLowerCase();
                const floor = parseInt(row.getAttribute('data-piso'));
                const state = row.getAttribute('data-estado');

                const matchesSearch = !searchLower || textContent.includes(searchLower);
                const matchesFloor = selectedFloors.includes(floor);
                const matchesState = selectedStates.includes(state);
                const matchesSala = selectedSala === 'all' || textContent.includes(selectedSala.toLowerCase());

                return matchesSearch && matchesFloor && matchesState && matchesSala;
            });

            const totalFiltered = filteredRows.length;
            const totalPages = Math.ceil(totalFiltered / pageSize) || 1;

            if (currentPage > totalPages) currentPage = totalPages;
            if (currentPage < 1) currentPage = 1;

            rows.forEach(row => row.style.display = 'none');

            const startIndex = (currentPage - 1) * pageSize;
            const endIndex = startIndex + pageSize;
            const pageRows = filteredRows.slice(startIndex, endIndex);

            pageRows.forEach(row => row.style.display = '');

            const infoEl = document.getElementById('pagination-info');
            if (infoEl) {
                if (totalFiltered === 0) {
                    infoEl.textContent = 'Mostrando 0 a 0 de 0 resultados';
                } else {
                    const from = startIndex + 1;
                    const to = Math.min(endIndex, totalFiltered);
                    infoEl.textContent = `Mostrando ${from} a ${to} de ${totalFiltered} resultados`;
                }
            }

            const btnPrev = document.getElementById('btnPagePrev');
            const btnNext = document.getElementById('btnPageNext');
            const btnNum = document.getElementById('btnPageNum');

            if (btnPrev) btnPrev.disabled = (currentPage <= 1);
            if (btnNext) btnNext.disabled = (currentPage >= totalPages || totalFiltered === 0);
            if (btnNum) btnNum.textContent = currentPage;
        }

        // Delegación de Eventos para Paginación y Búsqueda
        document.addEventListener('click', (e) => {
            if (e.target && e.target.closest('#btnPagePrev')) {
                if (currentPage > 1) {
                    currentPage--;
                    updateTableDisplay();
                }
            } else if (e.target && e.target.closest('#btnPageNext')) {
                currentPage++;
                updateTableDisplay();
            }
        });

        document.addEventListener('input', (e) => {
            if (e.target && e.target.classList.contains('panel-search-input')) {
                currentSearch = e.target.value;
                currentPage = 1;
                updateTableDisplay();
            }
        });

        document.addEventListener('change', (e) => {
            if (e.target && e.target.id === 'chkPisoAll') {
                const isChecked = e.target.checked;
                document.querySelectorAll('.filter-piso-checkbox').forEach(cb => {
                    cb.checked = isChecked;
                });
            } else if (e.target && e.target.classList.contains('filter-piso-checkbox')) {
                const allPisos = Array.from(document.querySelectorAll('.filter-piso-checkbox'));
                const checkedPisos = allPisos.filter(cb => cb.checked);
                const allCb = document.getElementById('chkPisoAll');
                if (allCb) {
                    allCb.checked = allPisos.length === checkedPisos.length;
                }
            }
        });

        document.addEventListener('click', (e) => {
            if (e.target && e.target.id === 'btnApplyFilters') {
                selectedFloors = Array.from(document.querySelectorAll('.filter-piso-checkbox:checked'))
                    .map(cb => parseInt(cb.value));
                selectedStates = Array.from(document.querySelectorAll('.filter-estado-checkbox:checked'))
                    .map(cb => cb.value);
                
                currentPage = 1;
                updateTableDisplay();

                const menu = e.target.closest('.filter-dropdown-menu');
                if (menu) menu.classList.remove('show');
            }
        });

        document.addEventListener('click', (e) => {
            if (e.target && e.target.id === 'btnCleanFilters') {
                const allCb = document.getElementById('chkPisoAll');
                if (allCb) allCb.checked = true;
                
                document.querySelectorAll('.filter-piso-checkbox').forEach(cb => cb.checked = true);
                document.querySelectorAll('.filter-estado-checkbox').forEach(cb => cb.checked = true);
                
                selectedFloors = [1, 2, 3];
                selectedStates = ['reservado', 'ocupado'];
                currentPage = 1;
                updateTableDisplay();

                const menu = e.target.closest('.filter-dropdown-menu');
                if (menu) menu.classList.remove('show');
            }
        });

        document.addEventListener('click', (e) => {
            if (e.target && e.target.classList.contains('btn-close-dropdown')) {
                const menu = e.target.closest('.filter-dropdown-menu');
                if (menu) menu.classList.remove('show');
            }
        });

        document.addEventListener('click', (e) => {
            const toggleBtn = e.target.closest('.filter-dropdown-toggle');
            
            if (toggleBtn) {
                const dropdownMenu = toggleBtn.nextElementSibling;
                if (dropdownMenu) {
                    dropdownMenu.classList.toggle('show');
                    syncCheckboxesFromState();
                }
                e.stopPropagation();
            } else {
                const insideFilterDropdown = e.target.closest('.filter-dropdown-menu');
                const insideNotifDropdown = e.target.closest('.notification-dropdown-menu, .notification-bell-container');
                
                if (!insideFilterDropdown && !insideNotifDropdown) {
                    document.querySelectorAll('.filter-dropdown-menu').forEach(menu => {
                        menu.classList.remove('show');
                    });
                }
            }
        });

        // Cambios de Pestañas (Vista de Lista vs. Timeline)
        let activeTab = 'lista';
        function abrirModalLiberarSinPenalizacion(reservaId, alumnoNombre, salaNombre) {
            document.getElementById('modalLiberarReservaId').value = reservaId;
            document.getElementById('modalLiberarAlumno').textContent = alumnoNombre;
            document.getElementById('modalLiberarSala').textContent = salaNombre;
            const modal = new bootstrap.Modal(document.getElementById('modalLiberarSinPenalizacion'));
            modal.show();
        }

        function abrirModalMarcarFalta(reservaId, alumnoNombre, salaNombre) {
            document.getElementById('modalFaltaReservaId').value = reservaId;
            document.getElementById('modalFaltaAlumno').textContent = alumnoNombre;
            document.getElementById('modalFaltaSala').textContent = salaNombre;
            const modal = new bootstrap.Modal(document.getElementById('modalMarcarFalta'));
            modal.show();
        }

        function refreshReservasContentArea() {
            activeTab = tab;
            const btnLista = document.getElementById('tabBtnLista');
            const btnTimeline = document.getElementById('tabBtnTimeline');
            const containerLista = document.getElementById('viewContainerLista');
            const containerTimeline = document.getElementById('viewContainerTimeline');

            if (tab === 'lista') {
                if (btnLista) btnLista.classList.add('active');
                if (btnTimeline) btnTimeline.classList.remove('active');
                if (containerLista) containerLista.style.display = 'block';
                if (containerTimeline) containerTimeline.style.display = 'none';
            } else {
                if (btnTimeline) btnTimeline.classList.add('active');
                if (btnLista) btnLista.classList.remove('active');
                if (containerTimeline) containerTimeline.style.display = 'block';
                if (containerLista) containerLista.style.display = 'none';
            }
        }

        let selectedSala = 'all';

        // Manejo de select de Piso, Sala y Estado directo
        document.addEventListener('change', (e) => {
            if (e.target && e.target.id === 'selectFilterPiso') {
                const val = e.target.value;
                selectedFloors = val === 'all' ? [1, 2, 3] : [parseInt(val)];
                currentPage = 1;
                syncCheckboxesFromState();
                updateTableDisplay();
            } else if (e.target && e.target.id === 'selectFilterSala') {
                selectedSala = e.target.value;
                currentPage = 1;
                updateTableDisplay();
            } else if (e.target && e.target.id === 'selectFilterEstado') {
                const val = e.target.value;
                selectedStates = val === 'all' ? ['reservado', 'ocupado'] : [val];
                currentPage = 1;
                syncCheckboxesFromState();
                updateTableDisplay();
            }
        });

        // Botón de Reset Rápido
        document.addEventListener('click', (e) => {
            if (e.target && e.target.closest('#btnQuickReset')) {
                selectedFloors = [1, 2, 3];
                selectedStates = ['reservado', 'ocupado'];
                selectedSala = 'all';
                currentSearch = '';
                currentPage = 1;

                const selPiso = document.getElementById('selectFilterPiso');
                const selSala = document.getElementById('selectFilterSala');
                const selEst = document.getElementById('selectFilterEstado');
                if (selPiso) selPiso.value = 'all';
                if (selSala) selSala.value = 'all';
                if (selEst) selEst.value = 'all';

                syncCheckboxesFromState();
                updateTableDisplay();
            } else if (e.target && e.target.closest('#btnFilterToggleHeader')) {
                const popup = document.querySelector('.filter-card-popup');
                if (popup) {
                    popup.classList.toggle('show');
                    syncCheckboxesFromState();
                }
                e.stopPropagation();
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            syncCheckboxesFromState();
            updateTableDisplay();
        });
    </script>
</body>
</html>
