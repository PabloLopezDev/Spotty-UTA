@{
    Layout = null;
    var nombreAdmin = ViewBag.NombreAdministrador as string ?? "Administrador";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestión de Salas - Spotty UTA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
</head>
<body class="admin-body">

    <div class="admin-layout">

        <!-- Sidebar Izquierda -->
        <aside class="admin-sidebar">
            <div class="sidebar-brand">
                <img src="/logo-uta.png" alt="Escudo UTA" class="brand-logo-img" />
                <h1 class="brand-text">SPOTTY <span>UTA</span></h1>
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a href="@Url.Action("Dashboard", "Administrador")" class="menu-item-link">
                        <i class="fa-solid fa-table-cells-large"></i>
                        <span class="menu-item-text">Dashboard</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ReservasActivas", "Administrador")" class="menu-item-link">
                        <i class="fa-regular fa-calendar-check"></i>
                        <span class="menu-item-text">Reservas Activas</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GestionSalas", "Administrador")" class="menu-item-link active">
                        <i class="fa-solid fa-door-open"></i>
                        <span class="menu-item-text">Gestión de Salas</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="menu-item-link">
                        <i class="fa-regular fa-user"></i>
                        <span class="menu-item-text">Usuarios</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="menu-item-link">
                        <i class="fa-solid fa-user-slash"></i>
                        <span class="menu-item-text">Usuarios Bloqueados</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="menu-item-link">
                        <i class="fa-regular fa-chart-bar"></i>
                        <span class="menu-item-text">Reportes</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="menu-item-link">
                        <i class="fa-solid fa-sliders"></i>
                        <span class="menu-item-text">Configuración</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                <a href="@Url.Action("CerrarSesion", "Auth")" class="sidebar-collapse-btn">
                    <i class="fa-solid fa-arrow-right-from-bracket text-danger"></i>
                    <span class="menu-item-text">Cerrar Sesión</span>
                </a>
            </div>
        </aside>

        <!-- Contenedor Principal -->
        <div class="admin-main-container">

            <!-- Top Header -->
            <header class="admin-top-header">
                <div class="d-flex align-items-center gap-3">
                    <span class="header-role-label">Administrador</span>
                    
                    @if (SpottyUTA.Helpers.SimulationTime.IsEnabled)
                    {
                        <form asp-controller="Administrador" asp-action="ToggleSimulationMode" method="post" class="d-inline-flex align-items-center m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="enable" value="false" />
                            <span class="badge bg-warning text-dark border me-2 py-1.5 px-3" style="font-size:0.75rem; border-radius: 8px;">
                                <i class="fa-solid fa-flask-vial me-1"></i> SIMULACIÓN ACTIVA (Lunes 10:00)
                            </span>
                            <button type="submit" class="btn btn-outline-danger btn-sm py-1 px-3 fw-bold" style="font-size:0.7rem; border-radius:6px;">
                                Desactivar
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="Administrador" asp-action="ToggleSimulationMode" method="post" class="d-inline-flex align-items-center m-0">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="enable" value="true" />
                            <button type="submit" class="btn btn-outline-primary btn-sm py-1 px-3 fw-medium" style="font-size:0.75rem; border-radius:6px;">
                                <i class="fa-solid fa-play me-1"></i> Modo Simulación (Probar)
                            </button>
                        </form>
                    }
                </div>

                <div class="header-user-profile">
                    <div class="dropdown">
                        <div class="profile-pill-trigger dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="profile-avatar-circle">
                                @(nombreAdmin.Length >= 2 ? nombreAdmin.Substring(0, 2).ToUpper() : "AD")
                            </div>
                            <span class="profile-name-text">@nombreAdmin</span>
                            <i class="fa-solid fa-chevron-down profile-chevron"></i>
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            <li><a class="dropdown-item text-danger" href="@Url.Action("CerrarSesion", "Auth")"><i class="fa-solid fa-right-from-bracket me-2"></i>Cerrar Sesión</a></li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Content Area (Updated via SignalR) -->
            <div id="gestion-salas-content-area">
                @await Html.PartialAsync("_GestionSalasContent")
            </div>

        </div>

    </div>

    <!-- Modal Bootstrap: Agregar Nueva Sala (Ubicado fuera del área refrescada por SignalR) -->
    <div class="modal fade" id="modalAgregarSala" tabindex="-1" aria-labelledby="modalAgregarSalaLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 18px;">
                <div class="modal-header border-bottom pb-3 px-4 pt-4">
                    <h5 class="modal-title fw-bold text-dark" id="modalAgregarSalaLabel">
                        <i class="fa-solid fa-plus-circle text-primary me-2"></i>Agregar Nueva Sala
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-controller="Administrador" asp-action="AgregarSala" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="activeTab" class="inputActiveTabVal" value="@(ViewBag.ActiveTab ?? "all")" />
                    <div class="modal-body px-4 py-3">
                        <div class="mb-3">
                            <label for="inputNombreSala" class="form-label fw-semibold text-dark small">Nombre de la Sala / Box</label>
                            <input type="text" class="form-control rounded-3 py-2" id="inputNombreSala" name="nombre" placeholder="Ej: Box 13" required autocomplete="off" />
                            <div class="form-text" style="font-size: 0.75rem;">Ingresa el nombre distintivo de la sala de estudio.</div>
                        </div>
                        <div class="mb-3">
                            <label for="selectPisoSala" class="form-label fw-semibold text-dark small">Piso / Ubicación</label>
                            <select class="form-select rounded-3 py-2" id="selectPisoSala" name="piso" required>
                                <option value="1">Primer Piso</option>
                                <option value="2">Segundo Piso</option>
                                <option value="3">Tercer Piso</option>
                            </select>
                            <div class="form-text" style="font-size: 0.75rem;">Selecciona el piso del edificio de biblioteca donde se ubica.</div>
                        </div>
                    </div>
                    <div class="modal-footer border-top px-4 py-3 bg-light" style="border-bottom-left-radius: 18px; border-bottom-right-radius: 18px;">
                        <button type="button" class="btn btn-outline-secondary btn-sm px-3 fw-semibold" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary btn-sm px-4 fw-bold">Guardar Sala</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Bootstrap: Confirmación de Eliminación Modernizada (Ubicado fuera del área refrescada) -->
    <div class="modal fade" id="modalConfirmarEliminarSala" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 18px;">
                <div class="modal-header border-0 pt-4 px-4 pb-0 text-center flex-column">
                    <div class="icon-bg-red mx-auto mb-3" style="width: 56px; height: 56px; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; background-color: #FEF2F2;">
                        <i class="fa-solid fa-triangle-exclamation text-danger"></i>
                    </div>
                    <h5 class="modal-title fw-bold text-dark mb-1">Confirmar eliminación</h5>
                    <p class="text-muted small mb-0">¿Estás seguro de que deseas eliminar la sala <strong id="deleteSalaNombreModal" class="text-dark">Box</strong>?</p>
                </div>
                <form asp-controller="Administrador" asp-action="EliminarSala" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="salaId" id="deleteSalaIdModal" value="0" />
                    <input type="hidden" name="activeTab" class="inputActiveTabVal" value="@(ViewBag.ActiveTab ?? "all")" />

                    <div class="modal-body px-4 py-3 text-center">
                        <p class="text-secondary small mb-0 bg-light p-3 rounded-3" style="font-size: 0.78rem;">
                            <i class="fa-solid fa-circle-info text-primary me-1"></i> Esta acción quitará la sala del sistema si no posee reservas activas.
                        </p>
                    </div>
                    <div class="modal-footer border-0 px-4 pb-4 pt-0 d-flex justify-content-center gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm px-4 py-2 fw-semibold" style="border-radius: 10px;" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-danger btn-sm px-4 py-2 fw-bold" style="border-radius: 10px;">
                            <i class="fa-solid fa-trash-can me-1"></i> Sí, Eliminar Sala
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        // Configuración de SignalR para refresco en tiempo real
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/salasHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ActualizarMatrizSalas", function () {
            refrescarGestionSalas();
        });

        connection.start().then(function () {
            console.log("SignalR conectado en Gestión de Salas.");
        }).catch(function (err) {
            console.error("Error al conectar SignalR en Gestión de Salas: ", err.toString());
        });

        let activePisoTab = '@(ViewBag.ActiveTab as string ?? "all")';

        function switchGestionPisoTab(piso) {
            activePisoTab = piso;
            const tabs = ['all', '1', '2', '3'];
            tabs.forEach(t => {
                const btn = document.getElementById(t === 'all' ? 'tabGestionPisoAll' : `tabGestionPiso${t}`);
                if (btn) {
                    if (t === piso) btn.classList.add('active');
                    else btn.classList.remove('active');
                }
            });

            // Sincronizar campo oculto en formularios para persistir la pestaña al enviar POST
            const inputs = document.querySelectorAll('.inputActiveTabVal');
            inputs.forEach(inp => inp.value = piso);

            filtrarSalasEnCliente();
        }

        function abrirModalEliminarSala(id, nombre) {
            const idInput = document.getElementById('deleteSalaIdModal');
            const nameSpan = document.getElementById('deleteSalaNombreModal');
            if (idInput && nameSpan) {
                idInput.value = id;
                nameSpan.innerText = nombre;
            }
            const modalElem = document.getElementById('modalConfirmarEliminarSala');
            if (modalElem) {
                const modal = new bootstrap.Modal(modalElem);
                modal.show();
            }
        }

        function limpiarModalesYBackdrops() {
            document.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
            document.body.classList.remove('modal-open');
            document.body.style.removeProperty('padding-right');
            document.body.style.removeProperty('overflow');
        }

        function refrescarGestionSalas() {
            // SI HAY UN MODAL ABIERTO EN ESTE MOMENTO, NO REEMPLAZAR EL DOM PARA NO INTERRUMPIR AL ADMINISTRADOR
            const modalAbierto = document.querySelector('.modal.show');
            if (modalAbierto) {
                return;
            }

            fetch(`/Administrador/GestionSalas?tab=${activePisoTab}&partial=true`)
                .then(response => response.text())
                .then(html => {
                    const area = document.getElementById('gestion-salas-content-area');
                    if (area) {
                        area.innerHTML = html;
                        limpiarModalesYBackdrops();
                        switchGestionPisoTab(activePisoTab);
                    }
                })
                .catch(err => console.error("Error al refrescar gestión de salas: ", err));
        }

        function filtrarSalasEnCliente() {
            const searchInput = document.getElementById('searchSalaInput');
            const selectEstado = document.getElementById('selectGestionEstado');

            if (!searchInput || !selectEstado) return;

            const query = searchInput.value.toLowerCase().trim();
            const valEstado = selectEstado.value;

            const cards = document.querySelectorAll('.sala-admin-card');

            cards.forEach(card => {
                const nombre = card.getAttribute('data-nombre') || '';
                const piso = card.getAttribute('data-piso');
                const isInhabilitada = card.getAttribute('data-inhabilitada') === 'true';

                const matchesSearch = !query || nombre.includes(query);
                const matchesPiso = activePisoTab === 'all' || piso === activePisoTab;
                
                let matchesEstado = true;
                if (valEstado === 'activa') matchesEstado = !isInhabilitada;
                else if (valEstado === 'inhabilitada') matchesEstado = isInhabilitada;

                if (matchesSearch && matchesPiso && matchesEstado) {
                    card.style.setProperty('display', 'flex', 'important');
                } else {
                    card.style.setProperty('display', 'none', 'important');
                }
            });
        }

        document.addEventListener('input', (e) => {
            if (e.target && e.target.id === 'searchSalaInput') {
                filtrarSalasEnCliente();
            }
        });

        document.addEventListener('change', (e) => {
            if (e.target && e.target.id === 'selectGestionEstado') {
                filtrarSalasEnCliente();
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            limpiarModalesYBackdrops();
            switchGestionPisoTab(activePisoTab);
        });
    </script>
</body>
</html>
