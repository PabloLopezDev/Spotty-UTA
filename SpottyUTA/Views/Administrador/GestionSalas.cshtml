@{
    Layout = null;
    var nombreAdmin = ViewBag.NombreAdministrador as string ?? "Administrador";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestión de Salas - Spotty UTA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
</head>
<body class="admin-body">

    <div class="admin-layout">

        <!-- Sidebar Izquierda -->
        <aside class="admin-sidebar">
            <div class="sidebar-brand">
                <img src="/logo-uta.png" alt="Escudo UTA" class="brand-logo-img" />
                <h1 class="brand-text">SPOTTY <span>UTA</span></h1>
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a href="@Url.Action("Dashboard", "Administrador")" class="menu-item-link">
                        <i class="fa-solid fa-border-all"></i>
                        <span class="menu-item-text">Dashboard</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ReservasActivas", "Administrador")" class="menu-item-link">
                        <i class="fa-regular fa-calendar-check"></i>
                        <span class="menu-item-text">Reservas Activas</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GestionSalas", "Administrador")" class="menu-item-link active">
                        <i class="fa-solid fa-door-open"></i>
                        <span class="menu-item-text">Gestión de Salas</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Usuarios", "Administrador")" class="menu-item-link">
                        <i class="fa-regular fa-user"></i>
                        <span class="menu-item-text">Usuarios</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                <a href="@Url.Action("CerrarSesion", "Auth")" class="sidebar-collapse-btn">
                    <i class="fa-solid fa-arrow-right-from-bracket text-danger"></i>
                    <span class="menu-item-text">Cerrar Sesión</span>
                </a>
            </div>
        </aside>

        <!-- Contenedor Principal -->
        <div class="admin-main-container">

            <!-- Top Header -->
            <header class="admin-top-header">
                <div class="d-flex align-items-center gap-3">
                    <span class="header-role-label">Administrador</span>
                </div>

                <div class="header-right-actions">
                    <!-- Campana Notificaciones con Dropdown Interactivo -->
                    <div class="dropdown">
                        <button type="button" class="btn notification-bell-container p-0 border-0" id="notifDropdownTriggerGestion" data-bs-toggle="dropdown" data-bs-display="static" data-bs-popper-config='{"placement":"bottom-end","modifiers":[{"name":"flip","enabled":false}]}' aria-expanded="false">
                            <i class="fa-regular fa-bell bell-icon"></i>
                            <span class="notification-badge" id="notifBadgeCountGestion">3</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end notification-dropdown-menu">
                            <div class="notif-header d-flex align-items-center justify-content-between">
                                <h6 class="fw-bold mb-0 text-dark d-flex align-items-center gap-2" style="font-size: 0.9rem;">
                                    <i class="fa-solid fa-bell text-primary"></i>
                                    <span>Notificaciones</span>
                                </h6>
                                <span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-2.5 py-1" style="font-size: 0.72rem; border-radius: 20px;">3 Nuevas</span>
                            </div>
                            <div style="max-height: 340px; overflow-y: auto;">
                                <!-- Notificación 1: Lleva a Reservas Activas -->
                                <a href="@Url.Action("ReservasActivas", "Administrador")" class="notif-item">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <span class="fw-bold text-dark d-flex align-items-center gap-2" style="font-size: 0.86rem;">
                                            <i class="fa-solid fa-triangle-exclamation text-warning"></i>
                                            <span>Box 3 próximo a vencer</span>
                                        </span>
                                        <span class="text-muted" style="font-size: 0.72rem; font-weight: 600;">Hace 5m</span>
                                    </div>
                                    <p class="mb-0 text-start text-secondary" style="font-size: 0.8rem; line-height: 1.45;">Quedan menos de 15 minutos para la reserva activa en Box 3.</p>
                                </a>

                                <!-- Notificación 2: Lleva a Usuarios -->
                                <a href="@Url.Action("Usuarios", "Administrador")" class="notif-item">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <span class="fw-bold text-dark d-flex align-items-center gap-2" style="font-size: 0.86rem;">
                                            <i class="fa-solid fa-user-xmark text-danger"></i>
                                            <span>Usuario sancionado</span>
                                        </span>
                                        <span class="text-muted" style="font-size: 0.72rem; font-weight: 600;">Hace 20m</span>
                                    </div>
                                    <p class="mb-0 text-start text-secondary" style="font-size: 0.8rem; line-height: 1.45;">El estudiante acumuló 3 faltas y fue bloqueado automáticamente.</p>
                                </a>

                                <!-- Notificación 3: Lleva a Gestión de Salas -->
                                <a href="@Url.Action("GestionSalas", "Administrador")" class="notif-item">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <span class="fw-bold text-dark d-flex align-items-center gap-2" style="font-size: 0.86rem;">
                                            <i class="fa-solid fa-circle-check text-success"></i>
                                            <span>Sistema Operativo</span>
                                        </span>
                                        <span class="text-muted" style="font-size: 0.72rem; font-weight: 600;">Hoy 08:00</span>
                                    </div>
                                    <p class="mb-0 text-start text-secondary" style="font-size: 0.8rem; line-height: 1.45;">12 boxes de estudio disponibles para reserva hoy.</p>
                                </a>
                            </div>
                            <div class="notif-footer">
                                <button type="button" class="btn btn-link text-decoration-none fw-bold p-0 d-inline-flex align-items-center gap-1.5 text-primary" style="font-size: 0.8rem;" onclick="marcarTodasNotificacionesLeidas();">
                                    <i class="fa-solid fa-check-double"></i>
                                    <span>Marcar todas como leídas</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Perfil Dropdown -->
                    <div class="admin-profile-dropdown">
                        <div class="profile-avatar-circle">
                            @(nombreAdmin.Length >= 2 ? nombreAdmin.Substring(0, 2).ToUpper() : "AD")
                        </div>
                        <span class="profile-name-text">@nombreAdmin</span>
                        <i class="fa-solid fa-chevron-down profile-chevron"></i>
                    </div>
                </div>
            </header>

            <!-- Content Area (Updated via SignalR) -->
            <div id="gestion-salas-content-area">
                @await Html.PartialAsync("_GestionSalasContent")
            </div>

        </div>

    </div>

    <!-- Modal Bootstrap: Agregar Nueva Sala (Ubicado fuera del área refrescada por SignalR) -->
    <div class="modal fade" id="modalAgregarSala" tabindex="-1" aria-labelledby="modalAgregarSalaLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 18px;">
                <div class="modal-header border-bottom pb-3 px-4 pt-4">
                    <h5 class="modal-title fw-bold text-dark" id="modalAgregarSalaLabel">
                        <i class="fa-solid fa-plus-circle text-primary me-2"></i>Agregar Nueva Sala
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-controller="Administrador" asp-action="AgregarSala" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="activeTab" class="inputActiveTabVal" value="@(ViewBag.ActiveTab ?? "all")" />
                    <div class="modal-body px-4 py-3">
                        <div class="mb-3">
                            <label for="inputNombreSala" class="form-label fw-semibold text-dark small">Nombre de la Sala / Box</label>
                            <input type="text" class="form-control rounded-3 py-2" id="inputNombreSala" name="nombre" placeholder="Ej: Box 13" required autocomplete="off" />
                            <div class="form-text" style="font-size: 0.75rem;">Ingresa el nombre distintivo de la sala de estudio.</div>
                        </div>
                        <div class="mb-3">
                            <label for="selectPisoSala" class="form-label fw-semibold text-dark small">Piso / Ubicación</label>
                            <select class="form-select rounded-3 py-2" id="selectPisoSala" name="piso" required>
                                <option value="1">Primer Piso</option>
                                <option value="2">Segundo Piso</option>
                                <option value="3">Tercer Piso</option>
                            </select>
                            <div class="form-text" style="font-size: 0.75rem;">Selecciona el piso del edificio de biblioteca donde se ubica.</div>
                        </div>
                    </div>
                    <div class="modal-footer border-top px-4 py-3 bg-light" style="border-bottom-left-radius: 18px; border-bottom-right-radius: 18px;">
                        <button type="button" class="btn btn-outline-secondary btn-sm px-3 fw-semibold" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary btn-sm px-4 fw-bold">Guardar Sala</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Bootstrap: Confirmación de Eliminación Modernizada (Ubicado fuera del área refrescada) -->
    <div class="modal fade" id="modalConfirmarEliminarSala" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 18px;">
                <div class="modal-header border-0 pt-4 px-4 pb-0 text-center flex-column">
                    <div class="icon-bg-red mx-auto mb-3" style="width: 56px; height: 56px; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; background-color: #FEF2F2;">
                        <i class="fa-solid fa-triangle-exclamation text-danger"></i>
                    </div>
                    <h5 class="modal-title fw-bold text-dark mb-1">Confirmar eliminación</h5>
                    <p class="text-muted small mb-0">¿Estás seguro de que deseas eliminar la sala <strong id="deleteSalaNombreModal" class="text-dark">Box</strong>?</p>
                </div>
                <form asp-controller="Administrador" asp-action="EliminarSala" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="salaId" id="deleteSalaIdModal" value="0" />
                    <input type="hidden" name="activeTab" class="inputActiveTabVal" value="@(ViewBag.ActiveTab ?? "all")" />

                    <div class="modal-body px-4 py-3 text-center">
                        <p class="text-secondary small mb-0 bg-light p-3 rounded-3" style="font-size: 0.78rem;">
                            <i class="fa-solid fa-circle-info text-primary me-1"></i> Esta acción quitará la sala del sistema si no posee reservas activas.
                        </p>
                    </div>
                    <div class="modal-footer border-0 px-4 pb-4 pt-0 d-flex justify-content-center gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm px-4 py-2 fw-semibold" style="border-radius: 10px;" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-danger btn-sm px-4 py-2 fw-bold" style="border-radius: 10px;">
                            <i class="fa-solid fa-trash-can me-1"></i> Sí, Eliminar Sala
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Bootstrap: Guía de Administración de Salas -->
    <div class="modal fade" id="modalGuiaGestionSalas" tabindex="-1" aria-labelledby="modalGuiaGestionSalasLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <div class="modal-header border-bottom px-4 py-3.5">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-bg-blue rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="fa-solid fa-sliders text-primary fs-5"></i>
                        </div>
                        <div>
                            <h5 class="modal-title fw-bold text-dark mb-0" id="modalGuiaGestionSalasLabel">
                                Guía de Administración y Operatividad de Boxes
                            </h5>
                            <span class="text-muted small">Instrucciones de gestión y estado técnico de salas por piso UTA</span>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">

                    <!-- Sección 1: Instructivo de Operaciones -->
                    <div class="mb-4">
                        <h6 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2" style="font-size: 0.95rem;">
                            <i class="fa-solid fa-circle-info text-primary"></i>
                            <span>Acciones de Gestión de Boxes</span>
                        </h6>

                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center gap-3 rounded-3" style="padding: 16px 20px; background-color: #ECFDF5; border-left: 5px solid #10B981;">
                                <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; font-size: 0.9rem;">
                                    <i class="fa-solid fa-toggle-on"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-success mb-1" style="font-size: 0.92rem;">Interruptor Habilitado</div>
                                    <div class="text-secondary small">El box está operativo en el sistema y disponible inmediatamente para reservas de los estudiantes.</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-3 rounded-3" style="padding: 16px 20px; background-color: #FFFBEB; border-left: 5px solid #F59E0B;">
                                <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; font-size: 0.9rem;">
                                    <i class="fa-solid fa-toggle-off"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-warning-emphasis mb-1" style="font-size: 0.92rem; color: #92400E !important;">Interruptor Desactivado</div>
                                    <div class="text-secondary small">Inhabilita la sala por mantenimiento, desinfección o reparaciones de equipamiento. La oculta del catálogo.</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-3 rounded-3" style="padding: 16px 20px; background-color: #F8FAFC; border-left: 5px solid #3B82F6;">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; font-size: 0.9rem;">
                                    <i class="fa-solid fa-plus"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-dark mb-1" style="font-size: 0.92rem;">Agregar Nueva Sala</div>
                                    <div class="text-secondary small">Presiona el botón azul superior "Agregar Sala" para dar de alta un nuevo box en cualquiera de los 3 pisos.</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-3 rounded-3" style="padding: 16px 20px; background-color: #FEF2F2; border-left: 5px solid #EF4444;">
                                <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px; font-size: 0.9rem;">
                                    <i class="fa-solid fa-trash-can"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-danger mb-1" style="font-size: 0.92rem;">Eliminar Box</div>
                                    <div class="text-secondary small">Remueve definitivamente la sala del sistema. Solo se permite si no tiene reservas activas en curso.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer border-top px-4 py-3 bg-light d-flex justify-content-end">
                    <button type="button" class="btn btn-primary px-4 py-2 fw-bold" style="border-radius: 10px; font-size: 0.85rem;" data-bs-dismiss="modal">
                        Entendido
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        function marcarTodasNotificacionesLeidas() {
            localStorage.setItem('spotty_notif_read_all', 'true');
            document.querySelectorAll('.notification-badge').forEach(b => b.style.display = 'none');
        }

        if (localStorage.getItem('spotty_notif_read_all') === 'true') {
            document.addEventListener('DOMContentLoaded', function () {
                document.querySelectorAll('.notification-badge').forEach(b => b.style.display = 'none');
            });
        }

        // Configuración de SignalR para refresco en tiempo real
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/salasHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ActualizarMatrizSalas", function () {
            refrescarGestionSalas();
        });

        connection.start().then(function () {
            console.log("SignalR conectado en Gestión de Salas.");
        }).catch(function (err) {
            console.error("Error al conectar SignalR en Gestión de Salas: ", err.toString());
        });

        let activePisoTab = '@(ViewBag.ActiveTab as string ?? "all")';

        function switchGestionPisoTab(piso) {
            activePisoTab = piso;
            const tabs = ['all', '1', '2', '3'];
            tabs.forEach(t => {
                const btn = document.getElementById(t === 'all' ? 'tabGestionPisoAll' : `tabGestionPiso${t}`);
                if (btn) {
                    if (t === piso) btn.classList.add('active');
                    else btn.classList.remove('active');
                }
            });

            // Sincronizar campo oculto en formularios para persistir la pestaña al enviar POST
            const inputs = document.querySelectorAll('.inputActiveTabVal');
            inputs.forEach(inp => inp.value = piso);

            filtrarSalasEnCliente();
        }

        function abrirModalEliminarSala(id, nombre) {
            const idInput = document.getElementById('deleteSalaIdModal');
            const nameSpan = document.getElementById('deleteSalaNombreModal');
            if (idInput && nameSpan) {
                idInput.value = id;
                nameSpan.innerText = nombre;
            }
            const modalElem = document.getElementById('modalConfirmarEliminarSala');
            if (modalElem) {
                const modal = new bootstrap.Modal(modalElem);
                modal.show();
            }
        }

        function limpiarModalesYBackdrops() {
            document.querySelectorAll('.modal-backdrop').forEach(el => el.remove());
            document.body.classList.remove('modal-open');
            document.body.style.removeProperty('padding-right');
            document.body.style.removeProperty('overflow');
        }

        function refrescarGestionSalas() {
            // SI HAY UN MODAL ABIERTO EN ESTE MOMENTO, NO REEMPLAZAR EL DOM PARA NO INTERRUMPIR AL ADMINISTRADOR
            const modalAbierto = document.querySelector('.modal.show');
            if (modalAbierto) {
                return;
            }

            fetch(`/Administrador/GestionSalas?tab=${activePisoTab}&partial=true`)
                .then(response => response.text())
                .then(html => {
                    const area = document.getElementById('gestion-salas-content-area');
                    if (area) {
                        area.innerHTML = html;
                        limpiarModalesYBackdrops();
                        switchGestionPisoTab(activePisoTab);
                    }
                })
                .catch(err => console.error("Error al refrescar gestión de salas: ", err));
        }

        function filtrarSalasEnCliente() {
            const searchInput = document.getElementById('searchSalaInput');
            const selectEstado = document.getElementById('selectGestionEstado');

            if (!searchInput || !selectEstado) return;

            const query = searchInput.value.toLowerCase().trim();
            const valEstado = selectEstado.value;

            const cards = document.querySelectorAll('.sala-admin-card');

            cards.forEach(card => {
                const nombre = card.getAttribute('data-nombre') || '';
                const piso = card.getAttribute('data-piso');
                const isInhabilitada = card.getAttribute('data-inhabilitada') === 'true';

                const matchesSearch = !query || nombre.includes(query);
                const matchesPiso = activePisoTab === 'all' || piso === activePisoTab;
                
                let matchesEstado = true;
                if (valEstado === 'activa') matchesEstado = !isInhabilitada;
                else if (valEstado === 'inhabilitada') matchesEstado = isInhabilitada;

                if (matchesSearch && matchesPiso && matchesEstado) {
                    card.style.setProperty('display', 'flex', 'important');
                } else {
                    card.style.setProperty('display', 'none', 'important');
                }
            });
        }

        document.addEventListener('input', (e) => {
            if (e.target && e.target.id === 'searchSalaInput') {
                filtrarSalasEnCliente();
            }
        });

        document.addEventListener('change', (e) => {
            if (e.target && e.target.id === 'selectGestionEstado') {
                filtrarSalasEnCliente();
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            limpiarModalesYBackdrops();
            switchGestionPisoTab(activePisoTab);
        });
    </script>
</body>
</html>
