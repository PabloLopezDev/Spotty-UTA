@{
    Layout = null;
    var nombreAdmin = ViewBag.NombreAdministrador as string ?? "Administrador";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel de Administración - Spotty UTA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
</head>
<body class="admin-body">

    <div class="admin-layout">

        <!-- Sidebar Izquierda -->
        <aside class="admin-sidebar">
            <div class="sidebar-brand">
                <img src="/logo-uta.png" alt="Escudo UTA" class="brand-logo-img" />
                <h1 class="brand-text">SPOTTY <span>UTA</span></h1>
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a href="@Url.Action("Dashboard", "Administrador")" class="menu-item-link active">
                        <i class="fa-solid fa-border-all"></i>
                        <span class="menu-item-text">Dashboard</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ReservasActivas", "Administrador")" class="menu-item-link">
                        <i class="fa-regular fa-calendar-check"></i>
                        <span class="menu-item-text">Reservas Activas</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GestionSalas", "Administrador")" class="menu-item-link">
                        <i class="fa-solid fa-door-open"></i>
                        <span class="menu-item-text">Gestión de Salas</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Usuarios", "Administrador")" class="menu-item-link">
                        <i class="fa-regular fa-user"></i>
                        <span class="menu-item-text">Usuarios</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                <a href="@Url.Action("CerrarSesion", "Auth")" class="sidebar-collapse-btn">
                    <i class="fa-solid fa-arrow-right-from-bracket text-danger"></i>
                    <span class="menu-item-text">Cerrar Sesión</span>
                </a>
            </div>
        </aside>

        <!-- Contenedor Principal -->
        <div class="admin-main-container">

            <!-- Top Header -->
            <header class="admin-top-header">
                <div class="d-flex align-items-center gap-3">
                    <span class="header-role-label">Administrador</span>
                </div>

                <div class="header-right-actions">
                    <!-- Campana Notificaciones con Dropdown Interactivo -->
                    <div class="dropdown">
                        <button type="button" class="btn notification-bell-container p-0 border-0" id="notifDropdownTriggerDashboard" data-bs-toggle="dropdown" data-bs-display="static" data-bs-popper-config='{"placement":"bottom-end","modifiers":[{"name":"flip","enabled":false}]}' aria-expanded="false">
                            <i class="fa-regular fa-bell bell-icon"></i>
                            <span class="notification-badge" id="notifBadgeCountDashboard">3</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end notification-dropdown-menu">
                            <div class="notif-header d-flex align-items-center justify-content-between">
                                <h6 class="fw-bold mb-0 text-dark d-flex align-items-center gap-2" style="font-size: 0.9rem;">
                                    <i class="fa-solid fa-bell text-primary"></i>
                                    <span>Notificaciones</span>
                                </h6>
                                <span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-2.5 py-1" style="font-size: 0.72rem; border-radius: 20px;">3 Nuevas</span>
                            </div>
                            <div style="max-height: 340px; overflow-y: auto;">
                                <!-- Notificación 1: Lleva a Reservas Activas -->
                                <a href="@Url.Action("ReservasActivas", "Administrador")" class="notif-item">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <span class="fw-bold text-dark d-flex align-items-center gap-2" style="font-size: 0.86rem;">
                                            <i class="fa-solid fa-triangle-exclamation text-warning"></i>
                                            <span>Box 3 próximo a vencer</span>
                                        </span>
                                        <span class="text-muted" style="font-size: 0.72rem; font-weight: 600;">Hace 5m</span>
                                    </div>
                                    <p class="mb-0 text-start text-secondary" style="font-size: 0.8rem; line-height: 1.45;">Quedan menos de 15 minutos para la reserva activa en Box 3.</p>
                                </a>

                                <!-- Notificación 2: Lleva a Usuarios -->
                                <a href="@Url.Action("Usuarios", "Administrador")" class="notif-item">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <span class="fw-bold text-dark d-flex align-items-center gap-2" style="font-size: 0.86rem;">
                                            <i class="fa-solid fa-user-xmark text-danger"></i>
                                            <span>Usuario sancionado</span>
                                        </span>
                                        <span class="text-muted" style="font-size: 0.72rem; font-weight: 600;">Hace 20m</span>
                                    </div>
                                    <p class="mb-0 text-start text-secondary" style="font-size: 0.8rem; line-height: 1.45;">El estudiante acumuló 3 faltas y fue bloqueado automáticamente.</p>
                                </a>

                                <!-- Notificación 3: Lleva a Gestión de Salas -->
                                <a href="@Url.Action("GestionSalas", "Administrador")" class="notif-item">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <span class="fw-bold text-dark d-flex align-items-center gap-2" style="font-size: 0.86rem;">
                                            <i class="fa-solid fa-circle-check text-success"></i>
                                            <span>Sistema Operativo</span>
                                        </span>
                                        <span class="text-muted" style="font-size: 0.72rem; font-weight: 600;">Hoy 08:00</span>
                                    </div>
                                    <p class="mb-0 text-start text-secondary" style="font-size: 0.8rem; line-height: 1.45;">12 boxes de estudio disponibles para reserva hoy.</p>
                                </a>
                            </div>
                            <div class="notif-footer">
                                <button type="button" class="btn btn-link text-decoration-none fw-bold p-0 d-inline-flex align-items-center gap-1.5 text-primary" style="font-size: 0.8rem;" onclick="marcarTodasNotificacionesLeidas();">
                                    <i class="fa-solid fa-check-double"></i>
                                    <span>Marcar todas como leídas</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Perfil Dropdown -->
                    <div class="admin-profile-dropdown">
                        <div class="profile-avatar-circle">
                            @{
                                var initials = "";
                                if (nombreAdmin.Contains(" "))
                                {
                                    var parts = nombreAdmin.Split(' ');
                                    if (parts.Length >= 2) initials = (parts[0][0].ToString() + parts[1][0].ToString()).ToUpper();
                                    else initials = parts[0][0].ToString().ToUpper();
                                }
                                else if (nombreAdmin.Length > 0)
                                {
                                    initials = nombreAdmin.Substring(0, Math.Min(2, nombreAdmin.Length)).ToUpper();
                                }
                                @initials
                            }
                        </div>
                        <span class="profile-name-text">@nombreAdmin</span>
                        <i class="fa-solid fa-chevron-down profile-chevron"></i>
                    </div>
                </div>
            </header>

            <!-- Dashboard Content Area (Updated in Real-Time via SignalR) -->
            <div id="dashboard-content-area">
                @await Html.PartialAsync("_DashboardContent")
            </div>

        </div>

    </div>

    <!-- Modal Bootstrap: Liberar Box Sin Penalización -->
    <div class="modal fade" id="modalLiberarSinPenalizacion" tabindex="-1" aria-labelledby="modalLiberarLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <form asp-controller="Reservas" asp-action="GestionarAccionDashboard" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="reservaId" id="modalLiberarReservaId" />
                    <input type="hidden" name="accion" value="liberar" />
                    
                    <div class="modal-header border-bottom px-4 pt-4 pb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background-color: #FEF3C7; color: #D97706;">
                                <i class="fa-solid fa-door-open fs-5"></i>
                            </div>
                            <div>
                                <h5 class="modal-title fw-bold text-dark mb-0" id="modalLiberarLabel">Liberar Box sin Penalización</h5>
                                <span class="text-muted small">Confirmación de liberación anticipada</span>
                            </div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body px-4 py-4 text-secondary" style="font-size: 0.92rem;">
                        <p class="mb-3">¿Estás seguro de que deseas liberar la reserva de <strong id="modalLiberarAlumno" class="text-dark"></strong> en la <strong id="modalLiberarSala" class="text-dark"></strong>?</p>
                        <div class="p-3 rounded-3 bg-light border text-muted d-flex align-items-start gap-3" style="font-size: 0.85rem;">
                            <i class="fa-solid fa-circle-info text-primary fs-5 flex-shrink-0 mt-0.5"></i>
                            <span>Esta acción dejará el box disponible de inmediato para otros estudiantes sin registrar inasistencias ni penalizar la cuenta del alumno.</span>
                        </div>
                    </div>

                    <div class="modal-footer border-top px-4 py-3 bg-light rounded-bottom-4">
                        <button type="button" class="btn btn-outline-secondary px-4 fw-semibold rounded-3" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn text-white px-4 fw-bold rounded-3 shadow-sm d-inline-flex align-items-center justify-content-center gap-2" style="background-color: #F59E0B; border: none;">
                            <i class="fa-solid fa-check"></i>
                            <span>Sí, Liberar Box</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Bootstrap: Marcar Inasistencia / Sancionar -->
    <div class="modal fade" id="modalMarcarFalta" tabindex="-1" aria-labelledby="modalFaltaLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <form asp-controller="Reservas" asp-action="GestionarAccionDashboard" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="reservaId" id="modalFaltaReservaId" />
                    <input type="hidden" name="accion" value="falta" />
                    
                    <div class="modal-header border-bottom px-4 pt-4 pb-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; background-color: #FEE2E2; color: #DC2626;">
                                <i class="fa-solid fa-user-xmark fs-5"></i>
                            </div>
                            <div>
                                <h5 class="modal-title fw-bold text-dark mb-0" id="modalFaltaLabel">Registrar Inasistencia</h5>
                                <span class="text-muted small">Sanción por no presentación</span>
                            </div>
                        </div>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <div class="modal-body px-4 py-4 text-secondary" style="font-size: 0.92rem;">
                        <p class="mb-3">¿Confirmas que el alumno <strong id="modalFaltaAlumno" class="text-dark"></strong> no asistió a su reserva en la <strong id="modalFaltaSala" class="text-dark"></strong>?</p>
                        <div class="p-3 rounded-3 bg-danger bg-opacity-10 border border-danger border-opacity-25 text-danger d-flex align-items-start gap-3" style="font-size: 0.85rem;">
                            <i class="fa-solid fa-triangle-exclamation fs-5 flex-shrink-0 mt-0.5"></i>
                            <span>Esta acción liberará la sala y sumará <strong>1 falta acumulada</strong> al alumno. Si alcanza 3 faltas será bloqueado.</span>
                        </div>
                    </div>

                    <div class="modal-footer border-top px-4 py-3 bg-light rounded-bottom-4">
                        <button type="button" class="btn btn-outline-secondary px-4 fw-semibold rounded-3" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-danger px-4 fw-bold rounded-3 shadow-sm d-inline-flex align-items-center justify-content-center gap-2">
                            <i class="fa-solid fa-gavel"></i>
                            <span>Registrar Inasistencia</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    
    <script>
        function marcarTodasNotificacionesLeidas() {
            localStorage.setItem('spotty_notif_read_all', 'true');
            document.querySelectorAll('.notification-badge').forEach(b => b.style.display = 'none');
        }

        if (localStorage.getItem('spotty_notif_read_all') === 'true') {
            document.addEventListener('DOMContentLoaded', function () {
                document.querySelectorAll('.notification-badge').forEach(b => b.style.display = 'none');
            });
        }

        function abrirModalLiberarSinPenalizacion(reservaId, alumnoNombre, salaNombre) {
            document.getElementById('modalLiberarReservaId').value = reservaId;
            document.getElementById('modalLiberarAlumno').textContent = alumnoNombre;
            document.getElementById('modalLiberarSala').textContent = salaNombre;
            const modal = new bootstrap.Modal(document.getElementById('modalLiberarSinPenalizacion'));
            modal.show();
        }

        function abrirModalMarcarFalta(reservaId, alumnoNombre, salaNombre) {
            document.getElementById('modalFaltaReservaId').value = reservaId;
            document.getElementById('modalFaltaAlumno').textContent = alumnoNombre;
            document.getElementById('modalFaltaSala').textContent = salaNombre;
            const modal = new bootstrap.Modal(document.getElementById('modalMarcarFalta'));
            modal.show();
        }
        // Conectar a SignalR Hub
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/salasHub")
            .withAutomaticReconnect()
            .build();

        // Variables de estado del panel
        let selectedFloors = [1, 2, 3]; // Pisos activos por defecto
        let selectedStates = ['reservado', 'ocupado']; // Estados activos por defecto
        let currentSearch = '';
        let currentPage = 1;
        const rowsPerPage = 5;

        // Función unificada que aplica Filtro + Búsqueda + Paginación
        function updateTableDisplay() {
            const rows = Array.from(document.querySelectorAll('.premium-data-table tbody tr'))
                .filter(row => !(row.cells.length === 1 && row.cells[0].classList.contains('text-muted')));
            
            const searchVal = currentSearch.toLowerCase().trim();

            // 1. Filtrar filas que coincidan con la Búsqueda AND los Filtros de Piso AND los Filtros de Estado
            const matchingRows = rows.filter(row => {
                // Filtro de Búsqueda
                const nameText = row.querySelector('.table-user-name')?.textContent.toLowerCase() || '';
                const emailText = row.querySelector('.table-user-sub')?.textContent.toLowerCase() || '';
                const salaText = row.cells[1]?.textContent.toLowerCase() || '';
                const matchesSearch = !searchVal || nameText.includes(searchVal) || emailText.includes(searchVal) || salaText.includes(searchVal);

                // Filtro de Piso
                const rowPiso = parseInt(row.getAttribute('data-piso') || '1');
                const matchesPiso = selectedFloors.includes(rowPiso);

                // Filtro de Estado
                const statusBadge = row.querySelector('.status-pill-badge');
                const isOcupado = statusBadge && statusBadge.classList.contains('badge-ocupado');
                const rowState = isOcupado ? 'ocupado' : 'reservado';
                const matchesState = selectedStates.includes(rowState);

                return matchesSearch && matchesPiso && matchesState;
            });

            // 2. Ocultar todas las filas inicialmente
            rows.forEach(row => row.style.display = 'none');

            // 3. Paginar únicamente las filas que coinciden
            const totalPages = Math.ceil(matchingRows.length / rowsPerPage);
            if (currentPage > totalPages) {
                currentPage = Math.max(1, totalPages);
            }

            const startIdx = (currentPage - 1) * rowsPerPage;
            const endIdx = currentPage * rowsPerPage;

            matchingRows.forEach((row, idx) => {
                if (idx >= startIdx && idx < endIdx) {
                    row.style.display = '';
                }
            });

            // 4. Renderizar botones de paginación
            renderPaginationButtons(totalPages, matchingRows.length);
        }

        function renderPaginationButtons(totalPages, totalItems) {
            const container = document.querySelector('.pagination-btn-group');
            const infoText = document.querySelector('.pagination-info-text');
            if (!container) return;

            container.innerHTML = '';

            // Botón Prev
            const prevBtn = document.createElement('button');
            prevBtn.className = 'btn-pagination-item';
            prevBtn.innerHTML = '<i class="fa-solid fa-chevron-left" style="font-size:0.75rem;"></i>';
            prevBtn.disabled = currentPage === 1;
            prevBtn.addEventListener('click', () => {
                if (currentPage > 1) {
                    currentPage--;
                    updateTableDisplay();
                }
            });
            container.appendChild(prevBtn);

            // Botones de Páginas
            for (let i = 1; i <= Math.max(1, totalPages); i++) {
                const pageBtn = document.createElement('button');
                pageBtn.className = `btn-pagination-item ${currentPage === i ? 'active' : ''}`;
                pageBtn.textContent = i;
                pageBtn.addEventListener('click', () => {
                    currentPage = i;
                    updateTableDisplay();
                });
                container.appendChild(pageBtn);
            }

            // Botón Next
            const nextBtn = document.createElement('button');
            nextBtn.className = 'btn-pagination-item';
            nextBtn.innerHTML = '<i class="fa-solid fa-chevron-right" style="font-size:0.75rem;"></i>';
            nextBtn.disabled = currentPage === totalPages || totalPages === 0;
            nextBtn.addEventListener('click', () => {
                if (currentPage < totalPages) {
                    currentPage++;
                    updateTableDisplay();
                }
            });
            container.appendChild(nextBtn);

            // Texto informativo de la paginación
            if (infoText && totalItems > 0) {
                const startNum = (currentPage - 1) * rowsPerPage + 1;
                const endNum = Math.min(currentPage * rowsPerPage, totalItems);
                infoText.textContent = `Mostrando ${startNum} a ${endNum} de ${totalItems} resultados`;
            } else if (infoText) {
                infoText.textContent = 'Mostrando 0 a 0 de 0 resultados';
            }
        }

        // Sincronizar checkboxes del DOM a partir del estado de JS
        function syncCheckboxesFromState() {
            document.querySelectorAll('.filter-piso-checkbox').forEach(cb => {
                cb.checked = selectedFloors.includes(parseInt(cb.value));
            });
            const allPisos = Array.from(document.querySelectorAll('.filter-piso-checkbox'));
            const checkedPisos = allPisos.filter(cb => cb.checked);
            const allCb = document.getElementById('chkPisoAll');
            if (allCb) {
                allCb.checked = allPisos.length === checkedPisos.length;
            }

            document.querySelectorAll('.filter-estado-checkbox').forEach(cb => {
                cb.checked = selectedStates.includes(cb.value);
            });
        }

        // Búsqueda en tiempo real (usando delegación de eventos)
        document.addEventListener('input', (e) => {
            if (e.target && e.target.classList.contains('panel-search-input')) {
                currentSearch = e.target.value;
                currentPage = 1; // Volver a la primera página al buscar
                updateTableDisplay();
            }
        });

        // Manejo del checkbox de "Seleccionar todos" los pisos
        document.addEventListener('change', (e) => {
            if (e.target && e.target.id === 'chkPisoAll') {
                const isChecked = e.target.checked;
                document.querySelectorAll('.filter-piso-checkbox').forEach(cb => {
                    cb.checked = isChecked;
                });
            } else if (e.target && e.target.classList.contains('filter-piso-checkbox')) {
                const allPisos = Array.from(document.querySelectorAll('.filter-piso-checkbox'));
                const checkedPisos = allPisos.filter(cb => cb.checked);
                const allCb = document.getElementById('chkPisoAll');
                if (allCb) {
                    allCb.checked = allPisos.length === checkedPisos.length;
                }
            }
        });

        // Aplicar filtros seleccionados en la tarjeta
        document.addEventListener('click', (e) => {
            if (e.target && e.target.id === 'btnApplyFilters') {
                selectedFloors = Array.from(document.querySelectorAll('.filter-piso-checkbox:checked'))
                    .map(cb => parseInt(cb.value));
                selectedStates = Array.from(document.querySelectorAll('.filter-estado-checkbox:checked'))
                    .map(cb => cb.value);
                
                currentPage = 1;
                updateTableDisplay();

                // Cerrar tarjeta de dropdown
                const menu = e.target.closest('.filter-dropdown-menu');
                if (menu) menu.classList.remove('show');
            }
        });

        // Limpiar filtros (volver al estado por defecto: todos seleccionados)
        document.addEventListener('click', (e) => {
            if (e.target && e.target.id === 'btnCleanFilters') {
                const allCb = document.getElementById('chkPisoAll');
                if (allCb) allCb.checked = true;
                
                document.querySelectorAll('.filter-piso-checkbox').forEach(cb => cb.checked = true);
                document.querySelectorAll('.filter-estado-checkbox').forEach(cb => cb.checked = true);
                
                selectedFloors = [1, 2, 3];
                selectedStates = ['reservado', 'ocupado'];
                currentPage = 1;
                updateTableDisplay();

                // Cerrar tarjeta de dropdown
                const menu = e.target.closest('.filter-dropdown-menu');
                if (menu) menu.classList.remove('show');
            }
        });

        // Cerrar desde el botón X de la tarjeta
        document.addEventListener('click', (e) => {
            if (e.target && e.target.classList.contains('btn-close-dropdown')) {
                const menu = e.target.closest('.filter-dropdown-menu');
                if (menu) menu.classList.remove('show');
            }
        });

        // Toggle manual de dropdowns para evitar dependencias de Bootstrap JS
        document.addEventListener('click', (e) => {
            const toggleBtn = e.target.closest('.filter-dropdown-toggle');
            const dotsBtn = e.target.closest('.btn-table-action-dots');
            
            if (toggleBtn) {
                // Filtro dropdown toggle
                const dropdownMenu = toggleBtn.nextElementSibling;
                if (dropdownMenu) {
                    dropdownMenu.classList.toggle('show');
                    // Sincronizar UI de checkboxes con el estado de JS antes de abrir
                    syncCheckboxesFromState();
                }
                e.stopPropagation();
            } else if (dotsBtn) {
                // Table row action menu dots toggle
                const dropdownMenu = dotsBtn.nextElementSibling;
                if (dropdownMenu) {
                    dropdownMenu.classList.toggle('show');
                }
                e.stopPropagation();
            } else {
                // Evitar cerrar el menú si se hace clic dentro de la tarjeta de filtros o menú de acciones
                const insideFilterDropdown = e.target.closest('.filter-dropdown-menu');
                const insideActionDropdown = e.target.closest('.action-dropdown-menu');
                const insideNotifDropdown = e.target.closest('.notification-dropdown-menu, .notification-bell-container');
                
                if (!insideFilterDropdown && !insideActionDropdown && !insideNotifDropdown) {
                    document.querySelectorAll('.filter-dropdown-menu, .action-dropdown-menu').forEach(menu => {
                        menu.classList.remove('show');
                    });
                }
            }
        });

        // Botón del banner para enfocar la tabla de reservas
        document.addEventListener('click', (e) => {
            if (e.target && e.target.classList.contains('btn-alert-banner')) {
                const tableCard = document.querySelector('.section-card-panel');
                if (tableCard) {
                    tableCard.scrollIntoView({ behavior: 'smooth' });
                }
            }
        });

        // Al recibir actualización de SignalR, refrescamos el contenido del dashboard de forma asíncrona
        connection.on("ActualizarMatrizSalas", async (payload) => {
            console.log("SignalR: Cambio detectado en base de datos. Actualizando panel...");
            try {
                // Conservar el término de búsqueda actual antes de re-inyectar
                const searchInput = document.querySelector('.panel-search-input');
                const termToPreserve = searchInput ? searchInput.value : '';

                const response = await fetch('@Url.Action("Dashboard", "Administrador")?partial=true');
                if (response.ok) {
                    const html = await response.text();
                    document.getElementById('dashboard-content-area').innerHTML = html;
                    console.log("SignalR: Panel de datos actualizado.");

                    // Restaurar término de búsqueda si existía
                    const newSearchInput = document.querySelector('.panel-search-input');
                    if (newSearchInput && termToPreserve) {
                        newSearchInput.value = termToPreserve;
                        currentSearch = termToPreserve;
                        newSearchInput.focus();
                    }

                    // Re-sincronizar el DOM con las variables de filtro de JS
                    syncCheckboxesFromState();
                    updateTableDisplay();
                } else {
                    console.error("Error en respuesta de servidor al actualizar panel.");
                }
            } catch (error) {
                console.error("Error al actualizar contenido del dashboard por AJAX:", error);
            }
        });

        // Inicialización al cargar la página
        document.addEventListener('DOMContentLoaded', () => {
            syncCheckboxesFromState();
            updateTableDisplay();
        });

        // Iniciar la conexión
        connection.start()
            .then(() => console.log("SignalR: Conectado al hub en Dashboard."))
            .catch(err => console.error("Error de conexión SignalR:", err.toString()));
    </script>
</body>
</html>
