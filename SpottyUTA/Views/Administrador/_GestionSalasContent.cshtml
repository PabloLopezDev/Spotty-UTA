@using SpottyUTA.Models
@{
    var salas = ViewBag.Salas as List<Sala> ?? new List<Sala>();
    var estadosSalasMap = ViewBag.EstadosSalasMap as Dictionary<int, string> ?? new Dictionary<int, string>();
    
    int kpiTotal = ViewBag.KpiTotalSalas != null ? (int)ViewBag.KpiTotalSalas : 0;
    int kpiActivas = ViewBag.KpiActivas != null ? (int)ViewBag.KpiActivas : 0;
    int kpiInhabilitadas = ViewBag.KpiInhabilitadas != null ? (int)ViewBag.KpiInhabilitadas : 0;
    
    var ahora = SpottyUTA.Helpers.SimulationTime.Now;

    var countPiso1 = salas.Count(s => s.Piso == 1);
    var countPiso2 = salas.Count(s => s.Piso == 2);
    var countPiso3 = salas.Count(s => s.Piso == 3);

    var activasPiso1 = salas.Count(s => s.Piso == 1 && s.EstadoActual != "I");
    var activasPiso2 = salas.Count(s => s.Piso == 2 && s.EstadoActual != "I");
    var activasPiso3 = salas.Count(s => s.Piso == 3 && s.EstadoActual != "I");

    var successMessage = TempData["SuccessMessage"] as string;
    var warningMessage = TempData["WarningMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
}

<main class="dashboard-content-wrapper" style="grid-template-columns: 1fr; gap: 24px; padding: 32px 36px;">

    <!-- Modal Centrado de Notificación / Confirmación -->
    @if (!string.IsNullOrEmpty(successMessage) || !string.IsNullOrEmpty(warningMessage) || !string.IsNullOrEmpty(errorMessage))
    {
        string notifTitle = !string.IsNullOrEmpty(successMessage) ? "Operación Exitosa" : !string.IsNullOrEmpty(warningMessage) ? "Advertencia del Sistema" : "Error en Operación";
        string notifIcon = !string.IsNullOrEmpty(successMessage) ? "fa-circle-check text-success" : !string.IsNullOrEmpty(warningMessage) ? "fa-triangle-exclamation text-warning" : "fa-circle-xmark text-danger";
        string notifMsg = (successMessage ?? warningMessage ?? errorMessage) ?? "";
        string iconBg = !string.IsNullOrEmpty(successMessage) ? "#ECFDF5" : !string.IsNullOrEmpty(warningMessage) ? "#FFFBEB" : "#FEF2F2";

        <div class="modal fade show d-block" id="modalNotificacionNotif" tabindex="-1" aria-hidden="true" style="background-color: rgba(15, 23, 42, 0.45); backdrop-filter: blur(2px);">
            <div class="modal-dialog modal-dialog-centered" style="max-width: 420px;">
                <div class="modal-content border-0 shadow-lg text-center p-4" style="border-radius: 20px;">
                    <div class="mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px; border-radius: 18px; background-color: @iconBg;">
                        <i class="fa-solid @notifIcon fs-2"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">@notifTitle</h5>
                    <p class="text-secondary small mb-4" style="font-size: 0.88rem; line-height: 1.5;">@notifMsg</p>
                    <div>
                        <button type="button" class="btn btn-primary w-100 py-2.5 fw-bold" style="border-radius: 12px; font-size: 0.88rem;" onclick="this.closest('.modal').remove();">
                            Entendido / Aceptar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Header de Sección -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1 d-flex align-items-center gap-3">
                <i class="fa-solid fa-door-open text-primary"></i>
                <span>Gestión de Salas</span>
            </h1>
            <p class="text-muted mb-0 small">Administra, agrega y controla el estado operativo de los boxes de estudio.</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <div class="date-picker-mock shadow-sm me-2">
                <i class="fa-regular fa-calendar-days"></i>
                <span>Hoy, @ahora.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-ES"))</span>
            </div>
            <button type="button" class="btn btn-outline-primary d-inline-flex align-items-center gap-2 px-3 py-2 fw-bold shadow-sm me-1" style="border-radius: 10px; font-size: 0.85rem;" data-bs-toggle="modal" data-bs-target="#modalGuiaGestionSalas">
                <i class="fa-solid fa-circle-info"></i> Guía y Operatividad
            </button>
            <button type="button" class="btn btn-primary d-inline-flex align-items-center gap-2 px-3 py-2 fw-bold shadow-sm" style="border-radius: 10px; font-size: 0.85rem;" data-bs-toggle="modal" data-bs-target="#modalAgregarSala">
                <i class="fa-solid fa-plus"></i> Agregar Sala
            </button>
        </div>
    </div>

    <!-- 4 Tarjetas KPI de Gestión -->
    <div class="kpi-grid-4">
        <!-- KPI 1: Total Salas -->
        <div class="kpi-card">
            <div class="kpi-card-header">
                <span class="kpi-title">Total Salas Registradas</span>
                <div class="kpi-icon-wrapper icon-bg-blue">
                    <i class="fa-solid fa-building text-primary"></i>
                </div>
            </div>
            <div class="d-flex align-items-baseline justify-content-between">
                <div class="kpi-value">@kpiTotal</div>
                <span class="badge bg-light text-secondary border px-2 py-1" style="font-size: 0.72rem;">Boxes de Estudio</span>
            </div>
            <div class="kpi-subtext text-muted mt-2">Distribuidas en 3 pisos</div>
        </div>

        <!-- KPI 2: Salas Activas -->
        <div class="kpi-card">
            <div class="kpi-card-header">
                <span class="kpi-title">Salas Operativas</span>
                <div class="kpi-icon-wrapper icon-bg-green">
                    <i class="fa-solid fa-circle-check text-success"></i>
                </div>
            </div>
            <div class="d-flex align-items-baseline justify-content-between">
                <div class="kpi-value text-success">@kpiActivas</div>
                <span class="text-success fw-semibold" style="font-size: 0.75rem;">
                    @((kpiTotal > 0 ? (int)Math.Round((double)kpiActivas / kpiTotal * 100) : 0))% activas
                </span>
            </div>
            <div class="kpi-subtext text-muted mt-2">Disponibles para reserva</div>
        </div>

        <!-- KPI 3: Inhabilitadas -->
        <div class="kpi-card">
            <div class="kpi-card-header">
                <span class="kpi-title">Salas Inhabilitadas</span>
                <div class="kpi-icon-wrapper icon-bg-red">
                    <i class="fa-solid fa-power-off text-danger"></i>
                </div>
            </div>
            <div class="d-flex align-items-baseline justify-content-between">
                <div class="kpi-value text-danger">@kpiInhabilitadas</div>
                <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1" style="font-size: 0.72rem;">Mantenimiento</span>
            </div>
            <div class="kpi-subtext text-muted mt-2">Ocultas para estudiantes</div>
        </div>

        <!-- KPI 4: Distribución por Piso -->
        <div class="kpi-card">
            <div class="kpi-card-header">
                <span class="kpi-title">Salas por Piso</span>
                <div class="kpi-icon-wrapper icon-bg-yellow">
                    <i class="fa-solid fa-layer-group text-warning"></i>
                </div>
            </div>
            <div class="d-flex align-items-baseline justify-content-between">
                <div class="kpi-value">3 Pisos</div>
                <span class="text-muted fw-semibold" style="font-size: 0.75rem;">P1: @countPiso1 | P2: @countPiso2 | P3: @countPiso3</span>
            </div>
            <div class="kpi-subtext text-muted mt-2">Edificio Biblioteca UTA</div>
        </div>
    </div>

    <!-- Pestañas de Navegación por Piso -->
    <div class="reservas-tabs-header">
        <button type="button" class="reservas-tab-btn active" id="tabGestionPisoAll" onclick="switchGestionPisoTab('all')">
            <i class="fa-solid fa-border-all"></i> Todas las Salas (@kpiTotal)
        </button>
        <button type="button" class="reservas-tab-btn" id="tabGestionPiso1" onclick="switchGestionPisoTab('1')">
            <i class="fa-solid fa-layer-group"></i> Primer Piso (@countPiso1)
        </button>
        <button type="button" class="reservas-tab-btn" id="tabGestionPiso2" onclick="switchGestionPisoTab('2')">
            <i class="fa-solid fa-layer-group"></i> Segundo Piso (@countPiso2)
        </button>
        <button type="button" class="reservas-tab-btn" id="tabGestionPiso3" onclick="switchGestionPisoTab('3')">
            <i class="fa-solid fa-layer-group"></i> Tercer Piso (@countPiso3)
        </button>
    </div>

    <!-- Panel de Ancho Completo (1 Column) -->
    <div class="admin-panel-card m-0 p-3">
        <!-- Buscador + Filtro de Operatividad -->
        <div class="d-flex align-items-center justify-content-between pb-3 mb-3 border-bottom flex-wrap gap-2">
            <div class="d-flex align-items-center gap-3">
                <div class="modern-search-wrapper" style="width: 320px;">
                    <i class="fa-solid fa-magnifying-glass modern-search-icon"></i>
                    <input type="text" class="modern-search-input" id="searchSalaInput" placeholder="Buscar sala por nombre (Ej: Box 1)..." style="width: 320px;" />
                </div>
                <select class="form-select rounded-3 py-1.5 border" id="selectGestionEstado" style="width: 180px; font-size: 0.85rem;" onchange="filtrarSalasEnCliente()">
                    <option value="all">Todos los estados</option>
                    <option value="activa">Operativas (Habilitadas)</option>
                    <option value="inhabilitada">Inhabilitadas</option>
                </select>
            </div>
            <span class="text-muted small fw-semibold" id="salasResultCountText">Mostrando todas las salas</span>
        </div>

        <!-- Grid de Tarjetas de Salas (Full Width) -->
        <div class="gestion-salas-grid" id="salasGrid">
            @if (!salas.Any())
            {
                <div class="text-center py-5 text-muted w-100 grid-span-full">
                    <i class="fa-solid fa-door-closed d-block fs-3 mb-2 opacity-50"></i>
                    <span>No hay salas creadas en el sistema. Presiona "Agregar Sala" para crear una.</span>
                </div>
            }
            else
            {
                foreach (var s in salas)
                {
                    string estadoEnLiveMap = estadosSalasMap.ContainsKey(s.Id) ? estadosSalasMap[s.Id] : "D";
                    bool isInhabilitada = s.EstadoActual == "I";

                    string liveStatusBadgeClass = isInhabilitada ? "bg-secondary text-white" :
                                                    estadoEnLiveMap == "O" ? "bg-danger text-white" :
                                                    estadoEnLiveMap == "R" ? "bg-warning text-dark" : "bg-success text-white";

                    string liveStatusText = isInhabilitada ? "Inhabilitada" :
                                            estadoEnLiveMap == "O" ? "Ocupada Ahora" :
                                            estadoEnLiveMap == "R" ? "Reservada Hoy" : "Disponible";

                    <div class="sala-admin-card p-4 border rounded-4 shadow-sm bg-white" data-nombre="@s.Nombre.ToLower()" data-piso="@s.Piso" data-estado-db="@s.EstadoActual" data-estado-live="@estadoEnLiveMap">
                        <div class="d-flex align-items-start justify-content-between mb-3">
                            <div>
                                <h3 class="fw-bold text-dark mb-1" style="font-size: 1.2rem;">@s.Nombre</h3>
                                <span class="badge bg-light text-secondary border px-2.5 py-1" style="font-size: 0.75rem;">
                                    <i class="fa-solid fa-layer-group text-primary me-1"></i>Piso @s.Piso
                                </span>
                            </div>
                            <span class="badge @liveStatusBadgeClass px-3 py-1.5 rounded-pill shadow-sm" style="font-size: 0.78rem; font-weight: 600;">
                                @liveStatusText
                            </span>
                        </div>

                        <div class="d-flex align-items-center justify-content-between p-3 rounded-3 my-3" style="background-color: #F8FAFC; border: 1px solid #E2E8F0;">
                            <span class="text-secondary small fw-semibold">Operatividad:</span>
                            <div class="form-check form-switch modern-switch m-0 p-0 d-flex align-items-center gap-2">
                                <form asp-controller="Administrador" asp-action="ToggleEstadoSala" method="post" id="formToggleSala_@s.Id" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="salaId" value="@s.Id" />
                                    <input type="hidden" name="activeTab" class="inputActiveTabVal" value="@(ViewBag.ActiveTab ?? "all")" />
                                    <input class="form-check-input ms-0" type="checkbox" role="switch" id="switchSala_@s.Id" @(!isInhabilitada ? "checked" : "") onchange="document.getElementById('formToggleSala_@s.Id').submit();">
                                </form>
                                <label class="form-check-label fw-bold small @(!isInhabilitada ? "text-success" : "text-secondary")" for="switchSala_@s.Id" style="cursor: pointer;">
                                    @(!isInhabilitada ? "Habilitado" : "Desactivado")
                                </label>
                            </div>
                        </div>

                        <div class="pt-1">
                            <button type="button" class="btn btn-outline-danger btn-sm w-100 py-2 fw-semibold d-inline-flex align-items-center justify-content-center gap-2" style="border-radius: 10px; font-size: 0.82rem;" onclick="abrirModalEliminarSala(@s.Id, '@s.Nombre')">
                                <i class="fa-solid fa-trash-can"></i>
                                <span>Eliminar Box</span>
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

</main>
