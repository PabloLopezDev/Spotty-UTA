@{
    Layout = null;
    var nombreAdmin = ViewBag.NombreAdministrador as string ?? "Administrador";
    var activeTab = ViewBag.ActiveTab as string ?? "all";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Gestión de Usuarios - Spotty UTA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
</head>
<body class="admin-body">

    <div class="admin-layout">

        <!-- Sidebar Izquierda -->
        <aside class="admin-sidebar">
            <div class="sidebar-brand">
                <img src="/logo-uta.png" alt="Escudo UTA" class="brand-logo-img" />
                <h1 class="brand-text">SPOTTY <span>UTA</span></h1>
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a href="@Url.Action("Dashboard", "Administrador")" class="menu-item-link">
                        <i class="fa-solid fa-border-all"></i>
                        <span class="menu-item-text">Dashboard</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("ReservasActivas", "Administrador")" class="menu-item-link">
                        <i class="fa-regular fa-calendar-check"></i>
                        <span class="menu-item-text">Reservas Activas</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("GestionSalas", "Administrador")" class="menu-item-link">
                        <i class="fa-solid fa-door-open"></i>
                        <span class="menu-item-text">Gestión de Salas</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Usuarios", "Administrador")" class="menu-item-link active">
                        <i class="fa-regular fa-user"></i>
                        <span class="menu-item-text">Usuarios</span>
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                <a href="@Url.Action("CerrarSesion", "Auth")" class="sidebar-collapse-btn">
                    <i class="fa-solid fa-arrow-right-from-bracket text-danger"></i>
                    <span class="menu-item-text">Cerrar Sesión</span>
                </a>
            </div>
        </aside>

        <!-- Contenedor Principal -->
        <div class="admin-main-container">

            <!-- Top Header -->
            <header class="admin-top-header">
                <div class="d-flex align-items-center gap-3">
                    <span class="header-role-label">Administrador</span>
                </div>

                <div class="header-right-actions">
                    <!-- Campana Notificaciones con Dropdown Interactivo -->
                    <div class="dropdown">
                        <button type="button" class="btn notification-bell-container p-0 border-0" id="notifDropdownTriggerUsuarios" data-bs-toggle="dropdown" data-bs-display="static" data-bs-popper-config='{"placement":"bottom-end","modifiers":[{"name":"flip","enabled":false}]}' aria-expanded="false">
                            <i class="fa-regular fa-bell bell-icon"></i>
                            <span class="notification-badge" id="notifBadgeCountUsuarios">3</span>
                        </button>
                        <div class="dropdown-menu dropdown-menu-end notification-dropdown-menu">
                            <div class="notif-header d-flex align-items-center justify-content-between">
                                <h6 class="fw-bold mb-0 text-dark d-flex align-items-center gap-2" style="font-size: 0.9rem;">
                                    <i class="fa-solid fa-bell text-primary"></i>
                                    <span>Notificaciones</span>
                                </h6>
                                <span class="badge bg-primary bg-opacity-10 text-primary fw-bold px-2.5 py-1" style="font-size: 0.72rem; border-radius: 20px;">3 Nuevas</span>
                            </div>
                            <div style="max-height: 340px; overflow-y: auto;">
                                <!-- Notificación 1: Lleva a Reservas Activas -->
                                <a href="@Url.Action("ReservasActivas", "Administrador")" class="notif-item">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <span class="fw-bold text-dark d-flex align-items-center gap-2" style="font-size: 0.86rem;">
                                            <i class="fa-solid fa-triangle-exclamation text-warning"></i>
                                            <span>Box 3 próximo a vencer</span>
                                        </span>
                                        <span class="text-muted" style="font-size: 0.72rem; font-weight: 600;">Hace 5m</span>
                                    </div>
                                    <p class="mb-0 text-start text-secondary" style="font-size: 0.8rem; line-height: 1.45;">Quedan menos de 15 minutos para la reserva activa en Box 3.</p>
                                </a>

                                <!-- Notificación 2: Lleva a Usuarios -->
                                <a href="@Url.Action("Usuarios", "Administrador")" class="notif-item">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <span class="fw-bold text-dark d-flex align-items-center gap-2" style="font-size: 0.86rem;">
                                            <i class="fa-solid fa-user-xmark text-danger"></i>
                                            <span>Usuario sancionado</span>
                                        </span>
                                        <span class="text-muted" style="font-size: 0.72rem; font-weight: 600;">Hace 20m</span>
                                    </div>
                                    <p class="mb-0 text-start text-secondary" style="font-size: 0.8rem; line-height: 1.45;">El estudiante acumuló 3 faltas y fue bloqueado automáticamente.</p>
                                </a>

                                <!-- Notificación 3: Lleva a Gestión de Salas -->
                                <a href="@Url.Action("GestionSalas", "Administrador")" class="notif-item">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <span class="fw-bold text-dark d-flex align-items-center gap-2" style="font-size: 0.86rem;">
                                            <i class="fa-solid fa-circle-check text-success"></i>
                                            <span>Sistema Operativo</span>
                                        </span>
                                        <span class="text-muted" style="font-size: 0.72rem; font-weight: 600;">Hoy 08:00</span>
                                    </div>
                                    <p class="mb-0 text-start text-secondary" style="font-size: 0.8rem; line-height: 1.45;">12 boxes de estudio disponibles para reserva hoy.</p>
                                </a>
                            </div>
                            <div class="notif-footer">
                                <button type="button" class="btn btn-link text-decoration-none fw-bold p-0 d-inline-flex align-items-center gap-1.5 text-primary" style="font-size: 0.8rem;" onclick="marcarTodasNotificacionesLeidas();">
                                    <i class="fa-solid fa-check-double"></i>
                                    <span>Marcar todas como leídas</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Perfil Dropdown -->
                    <div class="admin-profile-dropdown">
                        <div class="profile-avatar-circle">
                            @(nombreAdmin.Length >= 2 ? nombreAdmin.Substring(0, 2).ToUpper() : "AD")
                        </div>
                        <span class="profile-name-text">@nombreAdmin</span>
                        <i class="fa-solid fa-chevron-down profile-chevron"></i>
                    </div>
                </div>
            </header>

            <!-- Content Area -->
            <div id="usuarios-content-area">
                @await Html.PartialAsync("_UsuariosContent")
            </div>

        </div>

    </div>

    <!-- Modal Bootstrap: Reglamento de Sanciones UTA (Diseño Limpio y Plano) -->
    <div class="modal fade" id="modalReglamentoSanciones" tabindex="-1" aria-labelledby="modalReglamentoSancionesLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                <div class="modal-header border-bottom px-4 py-3.5">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-bg-blue rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="fa-solid fa-gavel text-primary fs-5"></i>
                        </div>
                        <div>
                            <h5 class="modal-title fw-bold text-dark mb-0" id="modalReglamentoSancionesLabel">
                                Reglamento de Sanciones e Inasistencias
                            </h5>
                            <span class="text-muted small">Normativa institucional y procedimientos de mesa de ayuda UTA</span>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">

                    <!-- Sección 1: Política de Inasistencias -->
                    <div class="mb-4">
                        <h6 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2" style="font-size: 0.95rem;">
                            <i class="fa-solid fa-book-bookmark text-primary"></i>
                            <span>Política de Inasistencias a Boxes</span>
                        </h6>

                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center justify-content-between rounded-3" style="padding: 16px 20px; background-color: #ECFDF5; border-left: 5px solid #10B981;">
                                <div class="pe-3">
                                    <div class="fw-bold text-success mb-1" style="font-size: 0.92rem;">
                                        <i class="fa-solid fa-circle-check me-2"></i>Acceso Habilitado
                                    </div>
                                    <div class="text-secondary small">El estudiante cumple puntualmente con sus reservas y puede solicitar boxes normalmente.</div>
                                </div>
                                <span class="badge bg-success text-white px-3 py-2 rounded-pill flex-shrink-0 fw-bold" style="font-size: 0.75rem;">0 Faltas</span>
                            </div>

                            <div class="d-flex align-items-center justify-content-between rounded-3" style="padding: 16px 20px; background-color: #FFFBEB; border-left: 5px solid #F59E0B;">
                                <div class="pe-3">
                                    <div class="fw-bold text-warning-emphasis mb-1" style="font-size: 0.92rem; color: #92400E !important;">
                                        <i class="fa-solid fa-triangle-exclamation me-2"></i>Advertencia / En Riesgo
                                    </div>
                                    <div class="text-secondary small">Ausencia en 1 ó 2 bloques asignados sin cancelación previa. Conserva acceso pero queda advertido.</div>
                                </div>
                                <span class="badge bg-warning text-dark px-3 py-2 rounded-pill flex-shrink-0 fw-bold" style="font-size: 0.75rem;">1 ó 2 Faltas</span>
                            </div>

                            <div class="d-flex align-items-center justify-content-between rounded-3" style="padding: 16px 20px; background-color: #FEF2F2; border-left: 5px solid #EF4444;">
                                <div class="pe-3">
                                    <div class="fw-bold text-danger mb-1" style="font-size: 0.92rem;">
                                        <i class="fa-solid fa-ban me-2"></i>Sanción Automática
                                    </div>
                                    <div class="text-secondary small">El sistema inhabilita automáticamente al usuario. No podrá agendar horas hasta presentar justificativo en mesón.</div>
                                </div>
                                <span class="badge bg-danger text-white px-3 py-2 rounded-pill flex-shrink-0 fw-bold" style="font-size: 0.75rem;">3 Faltas</span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4 text-muted opacity-25" />

                    <!-- Sección 2: Procedimientos de Administrador -->
                    <div>
                        <h6 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2" style="font-size: 0.95rem;">
                            <i class="fa-solid fa-hand-holding-hand text-primary"></i>
                            <span>Procedimientos de Mesa de Ayuda</span>
                        </h6>

                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center gap-3 rounded-3" style="padding: 16px 20px; background-color: #F8FAFC; border-left: 5px solid #3B82F6;">
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 38px; height: 38px; font-size: 0.9rem;">
                                    <i class="fa-solid fa-rotate-left"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-dark mb-1" style="font-size: 0.92rem;">Reiniciar Faltas (Reset)</div>
                                    <div class="text-secondary small">Restablece el contador de inasistencias a 0 y rehabilita al alumno en caso de suspensión imprevista de clases o urgencias.</div>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-3 rounded-3" style="padding: 16px 20px; background-color: #FEF2F2; border-left: 5px solid #EF4444;">
                                <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 38px; height: 38px; font-size: 0.9rem;">
                                    <i class="fa-solid fa-user-lock"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-danger mb-1" style="font-size: 0.92rem;">Bloqueo Manual</div>
                                    <div class="text-secondary small">Aplica una sanción preventiva inmediata por faltas al reglamento de convivencia en salas o mala conducta.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="modal-footer border-top px-4 py-3 bg-light d-flex justify-content-end">
                    <button type="button" class="btn btn-primary px-4 py-2 fw-bold" style="border-radius: 10px; font-size: 0.85rem;" data-bs-dismiss="modal">
                        Entendido
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function marcarTodasNotificacionesLeidas() {
            localStorage.setItem('spotty_notif_read_all', 'true');
            document.querySelectorAll('.notification-badge').forEach(b => b.style.display = 'none');
        }

        if (localStorage.getItem('spotty_notif_read_all') === 'true') {
            document.addEventListener('DOMContentLoaded', function () {
                document.querySelectorAll('.notification-badge').forEach(b => b.style.display = 'none');
            });
        }

        let activeUsuarioTab = '@activeTab';

        function switchUsuarioTab(tab) {
            activeUsuarioTab = tab;
            const tabs = ['all', 'habilitados', 'bloqueados', 'estudiantes', 'admins'];
            tabs.forEach(t => {
                const btnId = t === 'all' ? 'tabUsuarioAll' :
                              t === 'habilitados' ? 'tabUsuarioHabilitados' :
                              t === 'bloqueados' ? 'tabUsuarioBloqueados' :
                              t === 'estudiantes' ? 'tabUsuarioEstudiantes' : 'tabUsuarioAdmins';
                const btn = document.getElementById(btnId);
                if (btn) {
                    if (t === tab) btn.classList.add('active');
                    else btn.classList.remove('active');
                }
            });

            // Sincronizar campo oculto en formularios para persistir la pestaña al enviar POST
            const inputs = document.querySelectorAll('.inputActiveTabVal');
            inputs.forEach(inp => inp.value = tab);

            filtrarUsuariosEnCliente();
        }

        function filtrarUsuariosEnCliente() {
            const searchInput = document.getElementById('searchUsuarioInput');
            const query = searchInput ? searchInput.value.toLowerCase().trim() : '';

            const rows = document.querySelectorAll('.usuario-row');
            let visibleCount = 0;

            rows.forEach(row => {
                const nombre = row.getAttribute('data-nombre') || '';
                const correo = row.getAttribute('data-correo') || '';
                const isBloqueado = row.getAttribute('data-bloqueado') === 'true';
                const rol = row.getAttribute('data-rol') || '';

                const matchesSearch = !query || nombre.includes(query) || correo.includes(query);
                
                let matchesTab = true;
                if (activeUsuarioTab === 'habilitados') matchesTab = !isBloqueado;
                else if (activeUsuarioTab === 'bloqueados') matchesTab = isBloqueado;
                else if (activeUsuarioTab === 'estudiantes') matchesTab = (rol === 'estudiante');
                else if (activeUsuarioTab === 'admins') matchesTab = (rol === 'administrador');

                if (matchesSearch && matchesTab) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });

            const countText = document.getElementById('tableResultCountText');
            if (countText) {
                countText.innerText = `Mostrando ${visibleCount} registro(s)`;
            }
        }

        document.addEventListener('input', (e) => {
            if (e.target && e.target.id === 'searchUsuarioInput') {
                filtrarUsuariosEnCliente();
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            switchUsuarioTab(activeUsuarioTab);
        });
    </script>
</body>
</html>
