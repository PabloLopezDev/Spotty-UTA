@{
    Layout = null;
    var email = ViewBag.Email as string;
    var rol = ViewBag.Rol as string;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Completar Registro - Spotty UTA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body>

    <!-- Background Decorations -->
    <div class="bg-decorations">
        <div class="circle-dec circle-dec-1"></div>
        <div class="circle-dec circle-dec-2"></div>
        <div class="circle-dec circle-dec-3"></div>
    </div>

    <div class="login-wrapper">
        
        <!-- Header Section -->
        <div class="login-header">
            <img src="/logo-uta.png" alt="Logo Universidad de Tarapacá" class="header-logo" />
            <div class="header-text-container">
                <h1 class="header-title">SPOTTY <span class="highlight">UTA</span></h1>
                <p class="header-subtitle">Biblioteca UTA</p>
            </div>
        </div>

        <!-- Register Card -->
        <div class="card-login-figma">
            <span class="login-badge">Spotty UTA</span>

            <h3 class="card-title">Completar Perfil</h3>
            <p class="card-subtitle">Parece que es tu primer ingreso con este correo. Indícanos tus datos para registrarte.</p>

            <div class="bubble-info-register shadow-sm">
                <div class="mb-1"><strong><i class="fa-regular fa-envelope me-1"></i> Correo:</strong> <span class="text-secondary">@email</span></div>
                <div><strong><i class="fa-solid fa-user-tag me-1"></i> Rol Asignado:</strong> 
                    <span class="badge @(rol == "Administrador" ? "bg-danger-subtle text-danger border border-danger-subtle" : "bg-primary-subtle text-primary border border-primary-subtle")" style="font-size: 0.7rem; font-weight: 600;">
                        @(rol?.ToUpper() ?? "")
                    </span>
                </div>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger small d-flex align-items-center mb-4 gap-2 border-0 p-3 text-start" style="background-color: #fff5f5; color: #c53030; border-radius: 8px; font-weight: 500;">
                    <i class="fa-solid fa-circle-xmark" style="font-size: 1.1rem; flex-shrink: 0;"></i>
                    <span>@TempData["ErrorMessage"]</span>
                </div>
            }

            <form asp-controller="Auth" asp-action="CompletarRegistro" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@email" />
                <input type="hidden" name="rol" value="@rol" />

                <div class="form-group-uta">
                    <label class="form-label-uta">Nombre Completo</label>
                    <div class="input-container-uta">
                        <i class="fa-regular fa-user input-icon-uta"></i>
                        <input type="text" name="nombreCompleto" class="form-control form-control-uta" placeholder="Ej. Juan Pérez González" required autocomplete="off" autofocus />
                    </div>
                </div>

                <button type="submit" class="btn btn-acceder-figma">
                    <i class="fa-solid fa-user-plus"></i> Completar y Acceder
                </button>

                <a asp-controller="Auth" asp-action="Login" class="btn-volver-login">
                    Cancelar e ir al Login
                </a>
            </form>
        </div>

        <!-- Footer Copyright -->
        <div class="bottom-page-footer">
            © 2025 Universidad de Tarapacá - Sistema Spotty UTA
        </div>

    </div>

</body>
</html>
